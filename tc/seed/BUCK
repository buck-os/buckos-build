"""
Seed toolchain resolution.

Resolves the seed toolchain from one of three sources (highest priority first):

  1. buckos.seed_path  — local archive  (export_file at repo root)
  2. buckos.seed_url   — remote download (http_file)
  3. neither           — bootstrap from source (stage 1 cross-compiler)

To use a local prebuilt seed (drop seed-toolchain.zip at repo root):

  [buckos]
  seed_path = seed-toolchain.zip

To download a prebuilt seed:

  [buckos]
  seed_url = https://...
  seed_sha256 = abc123...

When a prebuilt seed is active, also declares //tc/seed:seed-archive-ref
as a stable alias to the archive target, used by tests.
"""

load(":defs.bzl", "seed_toolchain")

seed_toolchain()
