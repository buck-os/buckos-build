load("//defs:package_defs.bzl", "cmake_package")

# aemu - Android Emulator Utilities
# Common utility library for Android emulation, used by gfxstream and QEMU

cmake_package(
    name = "aemu",
    version = "0.1.2",
    src_uri = "https://android.googlesource.com/platform/hardware/google/aemu/+archive/refs/heads/main.tar.gz",
    sha256 = "de3f74d375d6a02acee6bbc8594c0c65adfff14f48cb201ca3f86e91fc5c805c",
    description = "Android emulation utilities library for common C++ functions",
    homepage = "https://android.googlesource.com/platform/hardware/google/aemu",
    license = "Apache-2.0",
    deps = [],
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_CXX_STANDARD=17",
        "-DCMAKE_C_STANDARD=11",
        "-DBUILD_SHARED_LIBS=ON",
        "-DAEMU_COMMON_GEN_PKGCONFIG=ON",
        "-DBUILD_STANDALONE=ON",
    ],
    visibility = ["PUBLIC"],
)
