load("//defs:package.bzl", "package")

# mercurial - Scalable distributed SCM tool
# Uses make install for proper installation.
package(
    build_rule = "binary",
    name = "mercurial",
    version = "6.6",
    url = "https://www.mercurial-scm.org/release/mercurial-6.6.tar.gz",
    sha256 = "6bfd71cba0df3b18de424216b30e2a541cca6e0104853d3334be80a2ab09a4ad",
    description = "Scalable distributed SCM tool",
    homepage = "https://www.mercurial-scm.org/",
    license = "GPL-2+",
    install_script = """
cd "$SRCS"

make install \
    PREFIX=/usr \
    DESTDIR="$OUT" \
    PYTHON=python3 \
    PURE=--pure
""",
    deps = [
        "//packages/linux/lang/python:python",
    ],
)
