load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "rr",
    version = "5.7.0",
    use_configure = {
        "multilib": ("-DENABLE_MULTILIB=ON", "-DENABLE_MULTILIB=OFF"),
    },
    url = "https://github.com/rr-debugger/rr/archive/refs/tags/5.7.0.tar.gz",
    sha256 = "f7affaaee7316effd3f0924c94bc452ef50d372b94470cafe8568efd88451447",
    description = "Record and replay framework for debugging",
    homepage = "https://rr-project.org/",
    license = "MIT",
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_TESTS=OFF",
        "-Ddisable32bit=ON",
    ],
    # Pass capnproto prefix to cmake so we can find schema import path
    cmake_dep_defines = {
        "CAPNPROTO_PREFIX": "//packages/linux/dev-libs/serialization/capnproto:capnproto",
    },
    # capnp compiler needs --import-path to find /capnp/c++.capnp schema.
    # Patch the cmake files to inject --import-path using the CAPNPROTO_PREFIX
    # variable that cmake_dep_defines will set to the dep's installed prefix.
    pre_configure_cmds = ["""
# Patch cmake files to add --import-path=${CAPNPROTO_PREFIX}/include to capnp compile
# Note: CAPNPROTO_PREFIX will be set as a cmake define by cmake_dep_defines.
# The value will be <dep-prefix>/usr, so the include dir is ${CAPNPROTO_PREFIX}/include.
find . -name '*.cmake' -o -name 'CMakeLists.txt' | while read f; do
    sed -i 's|COMMAND capnp compile|COMMAND capnp compile --import-path=\${CAPNPROTO_PREFIX}/include|g' "$f" 2>/dev/null || true
    sed -i 's|COMMAND \${CAPNP_EXECUTABLE} compile|COMMAND \${CAPNP_EXECUTABLE} compile --import-path=\${CAPNPROTO_PREFIX}/include|g' "$f" 2>/dev/null || true
    sed -i 's|COMMAND capnpc|COMMAND capnpc --import-path=\${CAPNPROTO_PREFIX}/include|g' "$f" 2>/dev/null || true
done
"""],
    host_deps = [
        "//packages/linux/dev-libs/serialization/capnproto:capnproto",
    ],
    deps = [
        "//packages/linux/dev-libs/serialization/capnproto:capnproto",
        "//packages/linux/system/libs/compression/brotli:brotli",
        "//packages/linux/core/zlib:zlib",
    ],
)
