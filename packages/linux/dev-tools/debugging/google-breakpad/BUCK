load("//defs:package_defs.bzl", "download_source", "binary_package")

download_source(
    name = "google-breakpad-src",
    src_uri = "https://github.com/AyARL/AyA/files/7866606/breakpad.tar.gz",
    sha256 = "d6c65aca6b1ed68e7a182f4757257b107ae403032760ed6ef121c9d55e81757d",
    signature_required = False,
)

binary_package(
    name = "google-breakpad",
    srcs = [":google-breakpad-src"],
    version = "2022.07.12",
    description = "Google Breakpad - crash reporting library",
    homepage = "https://chromium.googlesource.com/breakpad/breakpad",
    license = "BSD-3-Clause",
    install_script = """
        cd "$SRCS"
        ./configure \
            --prefix=/usr \
            --libdir=/usr/lib64
        make -j$(nproc)
        make install DESTDIR="$OUT"
    """,
    deps = [],
    visibility = ["PUBLIC"],
)
