load("//defs:package_defs.bzl", "autotools_package")

# GDB - The GNU Debugger

autotools_package(
    name = "gdb",
    version = "14.1",
    src_uri = "https://ftp.gnu.org/gnu/gdb/gdb-14.1.tar.xz",
    sha256 = "d66df51276143451fcbff464cc8723d68f1e9df45a6a2d5635a54e71643edb80",
    description = "The GNU Debugger",
    homepage = "https://www.gnu.org/software/gdb/",
    license = "GPL-3.0",
    iuse = ["python", "tui", "source-highlight"],
    use_defaults = ["python", "tui"],
    deps = [
        "//packages/linux/core/ncurses:ncurses",
        "//packages/linux/core/readline:readline",
        "//packages/linux/system/libs/utility/gmp:gmp",
        "//packages/linux/system/libs/utility/mpfr:mpfr",
    ],
    use_deps = {
        "python": ["//packages/linux/lang/python:python"],
    },
    configure_args = [
        "--prefix=${PREFIX}",
        "--enable-shared",
        "--disable-static",
        "--with-system-readline",
        "--with-system-zlib",
        "--with-expat",
    ],
    visibility = ["PUBLIC"],
)
