load("//defs:package_defs.bzl", "download_source", "autotools_package")

# crash - Linux kernel crash dump analysis tool
#
# The crash utility is a kernel crash dump debugger and live system analysis tool.
# It is loosely based on the SVR4 crash command, but has been completely integrated
# with gdb in order to display formatted kernel data structures, disassemble source
# code, etc. It can investigate either live systems or kernel core dumps created from
# dump creation facilities such as kdump, netdump, diskdump, xendump, and others.
#
# Supports multiple architectures: x86, x86_64, ARM, ARM64, PPC, PPC64, IA64,
# MIPS, RISCV64, S390, S390X, Alpha, Sparc64, and LoongArch64.
#
# Note: crash builds its own embedded version of gdb during compilation, so the
# build process downloads gdb sources automatically if not present.

# Using fbsource reference to the vendored crash sources
download_source(
    name = "crash-src",
    src_uri = "fbsource://third-party/crash/9.0.0++",
    signature_required = False,
)

autotools_package(
    name = "crash",
    source = ":crash-src",
    version = "9.0.0",
    description = "Linux kernel crash dump analysis and debugging tool",
    homepage = "https://github.com/crash-utility/crash",
    license = "GPL-3.0",
    deps = [
        "//packages/linux/core/ncurses:ncurses",
        "//packages/linux/core/zlib:zlib",
        "//packages/linux/system/libs/compression/lzo:lzo",
        "//packages/linux/system/libs/compression/snappy:snappy",
        "//packages/linux/system/libs/compression/zstd:zstd",
        "//packages/linux/system/libs/utility/gmp:gmp",
        "//packages/linux/system/libs/utility/mpfr:mpfr",
        "//packages/linux/dev-tools/parsers/bison:bison",
        "//packages/linux/dev-tools/documentation/texinfo:texinfo",
    ],
    # crash uses its own custom configure script (not autotools)
    # The build system runs ./configure which generates build configuration,
    # then downloads and builds gdb, and finally builds crash
    configure_args = [],
    pre_configure = """
# crash uses its own configure script (configure.c compiled and run)
# The standard make process handles everything:
# 1. Runs ./configure to detect system and set up build
# 2. Downloads gdb tarball if needed (or we provide it)
# 3. Patches and builds gdb with crash integration
# 4. Builds crash binary

# Build crash - this will handle configure, gdb download/build, and crash build
make -j$(nproc)
""",
    # Override the install phase to install the crash binary and man page
    post_install = """
mkdir -p "$DESTDIR/usr/bin"
cp crash "$DESTDIR/usr/bin/"
if [ -f crash.8 ]; then
    mkdir -p "$DESTDIR/usr/share/man/man8"
    cp crash.8 "$DESTDIR/usr/share/man/man8/"
fi
""",
    visibility = ["PUBLIC"],
)
