load("//defs:package.bzl", "package")

# Perfetto - System profiling, app tracing and trace analysis

package(
    build_rule = "cmake",
    name = "perfetto",
    version = "46.0",
    url = "https://github.com/google/perfetto/archive/refs/tags/v46.0.tar.gz",
    sha256 = "dfc9b645c020d7a7469bae73d7432545b8005411c8176f46f04875058df0aa97",
    description = "System profiling, app tracing and trace analysis",
    homepage = "https://perfetto.dev/",
    license = "Apache-2.0",
    deps = [
        "//packages/linux/core/zlib:zlib",
    ],
    cmake_subdir = "sdk",
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DPERFETTO_BUILD_SDK_ONLY=ON",
    ],
    pre_configure_cmds = ["""
# Perfetto SDK has a CMakeLists.txt in sdk/ subdirectory
# Create a minimal CMakeLists.txt at root if missing
if [ ! -f CMakeLists.txt ] && [ -f sdk/CMakeLists.txt ]; then
    cp sdk/CMakeLists.txt CMakeLists.txt
fi
"""],
)
