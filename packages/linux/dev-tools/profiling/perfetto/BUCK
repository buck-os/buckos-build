load("//defs:package.bzl", "package")

# Perfetto - System profiling, app tracing and trace analysis

package(
    build_rule = "binary",
    name = "perfetto",
    version = "46.0",
    url = "https://github.com/google/perfetto/archive/refs/tags/v46.0.tar.gz",
    sha256 = "dfc9b645c020d7a7469bae73d7432545b8005411c8176f46f04875058df0aa97",
    description = "System profiling, app tracing and trace analysis",
    homepage = "https://perfetto.dev/",
    license = "Apache-2.0",
    deps = [
        "//packages/linux/core/zlib:zlib",
    ],
    install_script = """
cd "$SRCS"

# Build the perfetto SDK as a shared library
$CXX $CXXFLAGS -std=c++17 -fPIC -DPERFETTO_SDK_IMPL -I sdk -c sdk/perfetto.cc -o perfetto.o
$CXX $LDFLAGS -shared -o libperfetto.so perfetto.o -lpthread

mkdir -p "$OUT/usr/lib64" "$OUT/usr/include"
cp libperfetto.so "$OUT/usr/lib64/"
cp sdk/perfetto.h "$OUT/usr/include/"
""",
)
