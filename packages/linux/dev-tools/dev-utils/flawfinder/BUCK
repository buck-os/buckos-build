load("//defs:package.bzl", "package")

# flawfinder - Examines C/C++ source code for security flaws
# This has a setup.py and installs as a Python package.
package(
    build_rule = "python",
    name = "flawfinder",
    version = "2.0.19",
    url = "https://github.com/david-a-wheeler/flawfinder/archive/refs/tags/2.0.19.tar.gz",
    sha256 = "33d1d6f3f60516ef41c1d4688e7fb1a1fad8f2cd58a3521790da8cb56a76804b",
    description = "Examines C/C++ source code for security flaws",
    homepage = "https://dwheeler.com/flawfinder/",
    license = "GPL-2+",
    use_setup_py = True,
    pre_configure_cmds = ['''
# The setup.py references flawfinder.1.gz but it's not pre-built.
# Create it from the man page source if it exists, or create a stub.
if [ -f flawfinder.1 ] && ! [ -f flawfinder.1.gz ]; then
    gzip -k flawfinder.1 || gzip -c flawfinder.1 > flawfinder.1.gz
elif ! [ -f flawfinder.1.gz ]; then
    # No man page source either - remove data_files from setup.py
    sed -i "/data_files/,/\\]/d" setup.py || true
fi
'''],
    deps = [
        "//packages/linux/lang/python:python",
        "//packages/linux/dev-libs/python/setuptools:setuptools",
    ],
)
