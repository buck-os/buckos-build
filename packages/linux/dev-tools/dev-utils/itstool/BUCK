load("//defs:package.bzl", "package")

# itstool - ITS-based XML translation tool
# This is a Python script with autotools build system.
package(
    build_rule = "binary",
    name = "itstool",
    url = "https://files.itstool.org/itstool/itstool-2.0.7.tar.bz2",
    sha256 = "6b9a7cd29a12bb95598f5750e8763cee78836a1a207f85b74d8b3275b27e87ca",
    version = "2.0.7",
    description = "ITS-based XML translation tool",
    homepage = "http://itstool.org",
    license = "GPL-3+",
    install_script = """
cd "$SRCS"

# Skip configure (needs python libxml2 at configure time) and install manually
mkdir -p "$OUT/usr/bin" "$OUT/usr/share/itstool"

# Install the main script
sed 's|@PYTHON@|/usr/bin/python3|g; s|@prefix@|/usr|g; s|@datadir@|/usr/share|g; s|@pkgdatadir@|/usr/share/itstool|g; s|@PACKAGE_VERSION@|2.0.7|g' itstool.in > "$OUT/usr/bin/itstool"
chmod +x "$OUT/usr/bin/itstool"

# Install data files
cp -r its/*.its "$OUT/usr/share/itstool/" 2>/dev/null || true
""",
    deps = [
        "//packages/linux/lang/python:python",
        "//packages/linux/system/libs/data/libxml2:libxml2",
    ],
)
