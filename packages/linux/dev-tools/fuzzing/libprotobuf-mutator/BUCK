load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "libprotobuf-mutator",
    version = "1.3",
    url = "https://github.com/google/libprotobuf-mutator/archive/refs/tags/v1.3.tar.gz",
    sha256 = "1ee3473a6b0274494fce599539605bb19305c0efadc62b58d645812132c31baa",
    configure_args = [
        "-DLIB_PROTO_MUTATOR_TESTING=OFF",
        "-DLIB_PROTO_MUTATOR_DOWNLOAD_PROTOBUF=OFF",
        "-DCMAKE_CXX_FLAGS=-DHAVE_PTHREAD -Wno-error",
        "-DCMAKE_BUILD_TYPE=Release",
    ],
    deps = [
        "//packages/linux/dev-libs/serialization/protobuf:protobuf",
        "//packages/linux/dev-libs/google/abseil-cpp:abseil-cpp",
    ],
    # Ensure abseil include path is found by protobuf headers
    pre_configure_cmds = ["""
# The protobuf headers include abseil headers directly.
# Ensure CMake can find abseil by looking through the dep directories.
sed -i 's/find_package(Protobuf REQUIRED)/find_package(Protobuf REQUIRED)\nfind_package(absl QUIET)/' CMakeLists.txt || true
"""],
)
