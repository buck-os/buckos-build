load("//defs:package_defs.bzl", "simple_package")

# Gradle - Build automation tool

simple_package(
    name = "gradle",
    version = "8.5",
    src_uri = "https://services.gradle.org/distributions/gradle-8.5-bin.zip",
    sha256 = "TODO",
    description = "A powerful build automation tool for the JVM",
    homepage = "https://gradle.org/",
    license = "Apache-2.0",
    deps = [
        "//packages/linux/lang/java:openjdk",
    ],
    build_commands = [
        "cp -r * ${PREFIX}/",
        "ln -s ${PREFIX}/bin/gradle ${PREFIX}/bin/gradle",
    ],
    visibility = ["PUBLIC"],
)
