load("//defs:package_defs.bzl", "download_source", "ebuild_package")
load("//defs:eclasses.bzl", "inherit")
load("//defs:use_flags.bzl", "set_use_flags")

# Automake cannot use autotools_package because it would create a circular dependency
# (autotools eclass depends on automake). Build it manually instead.
download_source(
    name = "automake-src",
    src_uri = "https://mirrors.kernel.org/gnu/automake/automake-1.16.5.tar.xz",
    sha256 = "f01d58cd6d9d77fbdca9eb4bbd5ead1988228fdb73d6f7a201f5f8d6b118b469",
    signature_sha256 = "3a161ab65921eed55e1a94251d97c8451d4ba3431b55ca560e95a951b5f1d73a",
    signature_required = False,
)

ebuild_package(
    name = "automake",
    source = ":automake-src",
    version = "1.16.5",
    category = "dev-tools/build-systems",
    slot = "0",
    description = "Tool for generating GNU Standards-compliant Makefiles",
    homepage = "https://www.gnu.org/software/automake/",
    license = "GPL-2+",

    pre_configure = '''
# Create custom autom4te.cfg with correct paths for Buck build environment
for dep_dir in $(echo $DEP_BASE_DIRS | tr ':' ' '); do
    if [ -d "$dep_dir/usr/share/autoconf" ] && [ -f "$dep_dir/usr/share/autoconf/autom4te.cfg" ]; then
        echo "Found autoconf in: $dep_dir"

        # Create custom autom4te.cfg with Buck-specific paths
        mkdir -p "$T/autoconf-config"
        sed "s|--prepend-include '/usr/share/autoconf'|--prepend-include '$dep_dir/usr/share/autoconf'|g" \
            "$dep_dir/usr/share/autoconf/autom4te.cfg" > "$T/autoconf-config/autom4te.cfg"

        # Export environment variables for autoconf tools
        export AUTOM4TE="$dep_dir/usr/bin/autom4te"
        export AUTOM4TE_CFG="$T/autoconf-config/autom4te.cfg"
        export PERL5LIB="$dep_dir/usr/share/autoconf:${PERL5LIB:-}"
        export AC_MACRODIR="$dep_dir/usr/share/autoconf"
        export M4PATH="$dep_dir/usr/share/autoconf"
        export PATH="$dep_dir/usr/bin:$PATH"

        echo "Created custom autom4te.cfg at: $T/autoconf-config/autom4te.cfg"
        echo "Testing autoconf:"
        which autoconf
        autoconf --version 2>&1 | head -1 || echo "autoconf test failed"
        echo "AUTOM4TE_CFG=$AUTOM4TE_CFG"
        break
    fi
done
''',

    src_configure = '''
# Re-export environment variables (they don't persist from pre_configure)
for dep_dir in $(echo $DEP_BASE_DIRS | tr ':' ' '); do
    if [ -f "$T/autoconf-config/autom4te.cfg" ]; then
        export AUTOM4TE_CFG="$T/autoconf-config/autom4te.cfg"
        export PERL5LIB="$dep_dir/usr/share/autoconf:${PERL5LIB:-}"
        export AC_MACRODIR="$dep_dir/usr/share/autoconf"
        export M4PATH="$dep_dir/usr/share/autoconf"
        export autom4te_perllibdir="$dep_dir/usr/share/autoconf"
        export trailer_m4="$dep_dir/usr/share/autoconf/autoconf/trailer.m4"
        echo "src_configure: Re-exported environment variables"
        break
    fi
done
echo "src_configure: AUTOM4TE_CFG=$AUTOM4TE_CFG"
echo "src_configure: trailer_m4=$trailer_m4"
echo "src_configure: PATH=$PATH"
which autoconf
autoconf --version 2>&1 | head -1 || echo "autoconf not working"

# Bypass autoconf working test by pre-caching the result
./configure \\
    ac_cv_prog_AUTOCONF_works=yes \\
    --prefix=/usr \\
    --build=$(gcc -dumpmachine) \\
    --host=$(gcc -dumpmachine) \\
    --mandir=/usr/share/man \\
    --infodir=/usr/share/info \\
    --datadir=/usr/share \\
    --sysconfdir=/etc \\
    --localstatedir=/var \\
    --libdir=/usr/lib64 \\
    --disable-doc
''',

    src_compile = '''
make -j$(nproc)
''',

    src_install = '''
make DESTDIR="$DESTDIR" install
''',

    bdepend = [
        "//packages/linux/dev-tools/build-systems/autoconf:autoconf",
    ],
    visibility = ["PUBLIC"],
)
