load("//defs/packages:cmake.bzl", "cmake_package")

# date (Howard Hinnant's date library) - A date and time library based on the C++11/14/17 <chrono> header

cmake_package(
    name = "tz",
    version = "3.0.1",
    source = "//packages/linux/dev-libs/misc/date:date-src",
    description = "A date and time library based on the C++11/14/17 <chrono> header",
    homepage = "https://github.com/HowardHinnant/date",
    license = "MIT",
    deps = [
        "//packages/linux/core/libcurl:curl",
    ],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_TZ_LIB=ON",
        "-DUSE_SYSTEM_TZ_DB=ON",
        "-DBUILD_SHARED_LIBS=ON",
        "-DENABLE_DATE_TESTING=OFF",
        "-DUSE_SYSTEM_TZ_DB=ON",
    ],
)
