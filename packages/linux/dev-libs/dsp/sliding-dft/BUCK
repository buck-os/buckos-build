load("//defs:package_defs.bzl", "binary_package", "download_source")

VERSION = "0.0.1"
COMMIT = "13e0121253c73f2e85e418a3ae960463c0fbf31f"

download_source(
    name = "sliding-dft-src",
    src_uri = "https://github.com/bronsonp/SlidingDFT/archive/{}.tar.gz".format(COMMIT),
    sha256 = "99d0bb8ed569a3b24ba7e914f0b9ef3178fa255d32388b3a4831875f5b678a85",
)

binary_package(
    name = "sliding-dft",
    version = VERSION,
    srcs = [":sliding-dft-src"],
    install_script = """
        mkdir -p "$OUT/usr/include"
        find "$WORK" -name "sliding-dft.hpp" -exec install -D -m644 {} "$OUT/usr/include/sliding-dft.hpp" \\;
    """,
    description = "C++ header-only library for efficient sliding DFT computation",
    homepage = "https://github.com/bronsonp/SlidingDFT",
    license = "MIT",
    deps = [],
    visibility = ["PUBLIC"],
)
