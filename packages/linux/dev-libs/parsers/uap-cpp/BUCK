load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "uap-cpp",
    version = "master",
    url = "https://github.com/ua-parser/uap-cpp/archive/e51ea6b39c7f5141bee801fbf9b187db6cc28e1d.tar.gz",
    sha256 = "c19396d415409580ef526b9652a1cf40e43eb99246639e4f9be891f3fe2c0ad0",
    description = "User-Agent string parser library for C++",
    homepage = "https://github.com/ua-parser/uap-cpp",
    license = "MIT",
    configure_args = [
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TESTING=OFF",
        "-DCMAKE_CXX_STANDARD=17",
    ],
    # Fix missing cstdint include in SnippetIndex.h for GCC 14+
    pre_configure_cmds = [
        "sed -i '1s/^/#include <cstdint>\\n/' internal/SnippetIndex.h || true",
        "sed -i '/add_executable.*Tests/,/target_link_libraries.*Tests/d' CMakeLists.txt || true",
        "sed -i '/UaParserTest/d' CMakeLists.txt || true",
        "sed -i '/GTest/d' CMakeLists.txt || true",
    ],
    deps = [
        "//packages/linux/dev-libs/text/re2:re2",
        "//packages/linux/dev-libs/yaml/yaml-cpp:yaml-cpp",
    ],
)
