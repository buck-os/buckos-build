load("//defs:package.bzl", "package")

# LuaJIT - Just-In-Time Compiler for Lua
# Uses Makefile directly, no configure step.
package(
    build_rule = "binary",
    name = "luajit",
    version = "2.1.0-beta3",
    url = "https://github.com/LuaJIT/LuaJIT/archive/refs/tags/v2.1.0-beta3.tar.gz",
    sha256 = "409f7fe570d3c16558e594421c47bdd130238323c9d6fd6c83dedd2aaeb082a8",
    description = "Just-In-Time Compiler for Lua",
    homepage = "https://luajit.org/",
    license = "MIT",
    install_script = """
cd "$SRCS"

make -j${MAKEOPTS:-$(nproc)} PREFIX=/usr BUILDMODE=dynamic Q= \
    CC="$CC" CFLAGS="$CFLAGS" LDFLAGS="$LDFLAGS"

make PREFIX=/usr DESTDIR="$OUT" INSTALL_LIB="$OUT/usr/lib64" install
""",
)
