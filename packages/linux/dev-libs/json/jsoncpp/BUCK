load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "jsoncpp",
    version = "1.9.5",
    url = "https://github.com/open-source-parsers/jsoncpp/archive/refs/tags/1.9.5.tar.gz",
    sha256 = "f409856e5920c18d0c2fb85276e24ee607d2a09b5e7d5f0a371368903c275da2",
    deps = [],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DJSONCPP_WITH_TESTS=OFF",
        "-DJSONCPP_WITH_POST_BUILD_UNITTEST=OFF",
    ],
    # CMake hardcodes absolute paths in the .pc file (exec_prefix=/usr,
    # libdir=/usr/lib64) instead of using variable references.  This breaks
    # pkg-config --define-prefix in cross-compilation: the linker finds
    # the HOST /usr/lib64/libjsoncpp.so instead of the dep's copy.
    post_install_cmds = ["""
        for pc in "$DESTDIR"/usr/lib64/pkgconfig/*.pc "$DESTDIR"/usr/lib/pkgconfig/*.pc; do
            [ -f "$pc" ] || continue
            sed -i \
                -e 's|^exec_prefix=/usr$|exec_prefix=${prefix}|' \
                -e 's|^libdir=/usr/lib64$|libdir=${exec_prefix}/lib64|' \
                -e 's|^libdir=/usr/lib$|libdir=${exec_prefix}/lib|' \
                -e 's|^includedir=/usr/include$|includedir=${prefix}/include|' \
                "$pc"
        done
    """],
)
