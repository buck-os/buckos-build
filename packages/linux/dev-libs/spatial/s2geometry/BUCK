load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "s2geometry",
    version = "0.10.0",
    url = "https://github.com/google/s2geometry/archive/refs/tags/v0.10.0.tar.gz",
    sha256 = "1c17b04f1ea20ed09a67a83151ddd5d8529716f509dde49a8190618d70532a3d",
    description = "Google S2 spherical geometry library",
    homepage = "https://github.com/google/s2geometry",
    license = "Apache-2.0",
    deps = [
        "//packages/linux/dev-libs/google/abseil-cpp:abseil-cpp",
        "//packages/linux/dev-libs/google/glog:glog",
        "//packages/linux/system/libs/crypto/openssl:openssl",
    ],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DWITH_GFLAGS=OFF",
        "-DWITH_GLOG=ON",
        "-DWITH_PYTHON=OFF",
        "-DBUILD_EXAMPLES=OFF",
        "-DBUILD_TESTS=OFF",
        "-DCMAKE_CXX_FLAGS=-Wno-error",
        "-DS2_USE_SYSTEM_INCLUDES=ON",
        # Use C++20 to match abseil 20240116 ABI expectations
        "-DCMAKE_CXX_STANDARD=20",
    ],
    # Patch s2geometry to work with abseil 20240116+
    pre_configure_cmds = ["""
# Remove -Werror flags from cmake files
find . -name CMakeLists.txt -exec sed -i 's/-Werror//g' {} + || true
"""],
)
