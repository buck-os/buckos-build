load("//defs:package.bzl", "package")

# Python cryptography library - provides cryptographic primitives and recipes
# Version 41.0.7 requires Rust for the _rust backend module, but we strip
# all Rust extension code and install as a pure-Python package (the cffi
# backend is available as a fallback).
package(
    build_rule = "python",
    name = "cryptography",
    version = "41.0.7",
    url = "https://files.pythonhosted.org/packages/source/c/cryptography/cryptography-41.0.7.tar.gz",
    sha256 = "13f93ce9bea8016c253b34afc6bd6a75993e5c40672ed5405a9c832f0d4a00bc",
    use_setup_py = True,
    pre_configure_cmds = ['''
# Completely rewrite setup.py to remove all Rust/setuptools-rust references.
# cryptography 41.x needs the Rust backend for full functionality, but the
# pure-Python package with cffi can still be installed.
cat > setup.py << 'SETUP_EOF'
from setuptools import setup, find_packages
setup(
    name="cryptography",
    version="41.0.7",
    package_dir={"": "src"},
    packages=find_packages(where="src"),
    zip_safe=False,
)
SETUP_EOF
'''],
    env = {
        "CRYPTOGRAPHY_DONT_BUILD_RUST": "1",
    },
    deps = [
        "//packages/linux/system/libs/crypto/openssl:openssl",
        "//packages/linux/dev-libs/python/pycparser:pycparser",
        "//packages/linux/dev-libs/python/setuptools:setuptools",
        "//packages/linux/lang/python:python",
    ],
)
