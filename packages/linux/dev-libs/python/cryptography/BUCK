load("//defs:package.bzl", "package")

# Python cryptography library - provides cryptographic primitives and recipes
# Version 41.0.7 requires Rust for the _rust backend module.
# Uses pip install with setuptools-rust.
package(
    build_rule = "python",
    name = "cryptography",
    version = "41.0.7",
    url = "https://files.pythonhosted.org/packages/source/c/cryptography/cryptography-41.0.7.tar.gz",
    sha256 = "13f93ce9bea8016c253b34afc6bd6a75993e5c40672ed5405a9c832f0d4a00bc",
    use_setup_py = True,
    env = {
        # Help setuptools-rust find the OpenSSL headers/libs from deps
        "OPENSSL_DIR": "",
    },
    deps = [
        "//packages/linux/system/libs/crypto/openssl:openssl",
        "//packages/linux/dev-libs/python/pycparser:pycparser",
        "//packages/linux/dev-libs/python/setuptools:setuptools",
        "//packages/linux/lang/python:python",
    ],
)
