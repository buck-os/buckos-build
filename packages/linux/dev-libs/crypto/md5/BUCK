load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "md5",
    version = "04d0d68",
    url = "https://github.com/BZFlag-Dev/bzflag/archive/04d0d68acb4960fc056f0c9b662abe82d373e540.tar.gz",
    sha256 = "4b87db0e598902caa7f562442bf0f5028b75e7317a403663190cc9f76f52e251",
    description = "MD5 hash implementation from bzflag",
    homepage = "https://github.com/BZFlag-Dev/bzflag",
    license = "RSA-MD",
    src_install = """
mkdir -p $INSTALL_DIR/usr/include
find . -name 'MD5.h' -exec cp {} $INSTALL_DIR/usr/include/ \; 2>/dev/null || true
find . -name 'MD5.cxx' -o -name 'MD5.cpp' -o -name 'md5.c' | head -1 | xargs -I{} cp {} $INSTALL_DIR/usr/include/ 2>/dev/null || true
""",
)
