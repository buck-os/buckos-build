load("//defs:package.bzl", "package")

package(
    name = "libtomcrypt",
    build_rule = "make",
    skip_configure = True,
    version = "1.18.2",
    url = "https://github.com/libtom/libtomcrypt/releases/download/v1.18.2/crypt-1.18.2.tar.xz",
    sha256 = "96ad4c3b8336050993c5bc2cf6c057484f2b0f9f763448151567fbab5e767b84",
    description = "Comprehensive, modular and portable cryptographic toolkit",
    homepage = "https://www.libtom.net/LibTomCrypt/",
    license = "Unlicense",
    src_compile = """
make -j${MAKEOPTS:-$(nproc)} -f makefile CFLAGS="$CFLAGS -DLTC_SOURCE -DLTC_NO_TEST -DUSE_LTM -fPIC" PREFIX=/usr
""",
    src_install = """
make -f makefile DESTDIR=$INSTALL_DIR PREFIX=/usr LIBPATH=/usr/lib64 INCPATH=/usr/include install
""",
)
