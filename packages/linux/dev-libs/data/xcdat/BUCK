load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "xcdat",
    version = "0.2.0",
    url = "https://github.com/kampersanda/xcdat/archive/refs/tags/v0.2.0.tar.gz",
    sha256 = "3430a8bcfcb159e9e354fb3b201961ef13ee79a163af08bb2c279724147f2013",
    description = "Fast compressed trie dictionary library (header-only)",
    homepage = "https://github.com/kampersanda/xcdat",
    license = "MIT",
    deps = [],
    # Header-only library - just install the headers
    install_script = """
mkdir -p "$OUT/usr/include"
cp -a include/xcdat "$OUT/usr/include/"
cp -a include/xcdat.hpp "$OUT/usr/include/"
""",
)
