load("//defs:package.bzl", "package")

# Outcome - Lightweight outcome<T> and result<T> library for C++14

package(
    build_rule = "binary",
    name = "outcome",
    version = "2.2.7",
    url = "https://github.com/ned14/outcome/archive/refs/tags/v2.2.7.tar.gz",
    sha256 = "553fd03bb9684be19dfa251bfa0064e69e30a95b6b0ba9a62d68f8ec4e31662a",
    description = "Lightweight outcome<T> and result<T> library for C++14",
    homepage = "https://ned14.github.io/outcome/",
    license = "Apache-2.0",
    deps = [],
    src_install = """
mkdir -p $INSTALL_DIR/usr/include
cp -r include/outcome $INSTALL_DIR/usr/include/
# Also install single-header version if available
if [ -f single-header/outcome.hpp ]; then
    cp single-header/outcome.hpp $INSTALL_DIR/usr/include/
fi
""",
)
