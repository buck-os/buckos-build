load("//defs:package.bzl", "package")

# Asio - Cross-platform C++ library for network programming (standalone)

package(
    build_rule = "binary",
    name = "asio",
    version = "1.28.2",
    url = "https://github.com/chriskohlhoff/asio/archive/refs/tags/asio-1-28-2.tar.gz",
    sha256 = "5705a0e403017eba276625107160498518838064a6dd7fd8b00b2e30c0ffbdee",
    description = "Cross-platform C++ library for network and low-level I/O programming",
    homepage = "https://think-async.com/Asio/",
    license = "BSL-1.0",
    deps = [],
    src_install = """
mkdir -p $INSTALL_DIR/usr/include
cp -r asio/include/* $INSTALL_DIR/usr/include/
""",
)
