load("//defs:package_defs.bzl", "cmake_package")

# Asio - Cross-platform C++ library for network programming (standalone)

cmake_package(
    name = "asio",
    version = "1.28.2",
    src_uri = "https://github.com/chriskohlhoff/asio/archive/refs/tags/asio-1-28-2.tar.gz",
    sha256 = "TODO",
    description = "Cross-platform C++ library for network and low-level I/O programming",
    homepage = "https://think-async.com/Asio/",
    license = "BSL-1.0",
    iuse = ["ssl"],
    use_defaults = ["ssl"],
    deps = [],
    use_deps = {
        "ssl": ["//packages/linux/system/libs/crypto/openssl:openssl"],
    },
    source_subdir = "asio",
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DASIO_STANDALONE=ON",
    ],
    visibility = ["PUBLIC"],
)
