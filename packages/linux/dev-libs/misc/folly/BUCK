load("//defs:package.bzl", "package")

# Folly - Facebook Open Source Library

package(
    build_rule = "cmake",
    name = "folly",
    version = "2024.01.01.00",
    url = "https://github.com/facebook/folly/archive/refs/tags/v2024.01.01.00.tar.gz",
    sha256 = "3043ad0bf552ea9d56eb8f824b701cbe72d04f818cbf8bc1052fba038f6ad021",
    description = "Facebook Open Source Library - C++ utilities",
    homepage = "https://github.com/facebook/folly",
    license = "Apache-2.0",
    use_configure = {
        "io-uring": ("-DENABLE_IO_URING=ON", "-DENABLE_IO_URING=OFF"),
        "llvm-libunwind": ("-DENABLE_LLVM_LIBUNWIND=ON", "-DENABLE_LLVM_LIBUNWIND=OFF"),
    },
    deps = [
        "//packages/linux/dev-libs/boost:boost",
        "//packages/linux/dev-libs/google/glog:glog",
        "//packages/linux/dev-libs/google/gflags:gflags",
        "//packages/linux/dev-libs/misc/double-conversion:double-conversion",
        "//packages/linux/system/libs/utility/libevent:libevent",
        "//packages/linux/system/libs/crypto/openssl:openssl",
        "//packages/linux/dev-libs/misc/fmt:fmt",
        "//packages/linux/core/zlib:zlib",
    ],
    use_deps = {
        "jemalloc": "//packages/linux/dev-libs/allocators/jemalloc:jemalloc",
        "lz4": "//packages/linux/system/libs/compression/lz4:lz4",
        "zstd": "//packages/linux/system/libs/compression/zstd:zstd",
        "snappy": "//packages/linux/system/libs/compression/snappy:snappy",
        "bzip2": "//packages/linux/system/libs/compression/bzip2:bzip2",
    },
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TESTS=OFF",
        "-DFOLLY_USE_JEMALLOC=OFF",
        "-DFOLLY_HAVE_JEMALLOC=0",
        "-DCMAKE_CXX_FLAGS=-Wno-error",
    ],
    # Fix glog 0.7.0 compatibility: MakeCheckOpValueString template
    # declaration order changed in glog 0.7, causing folly compilation failure.
    # Patch folly source files to add the missing forward declaration.
    pre_configure_cmds = ["""
# glog 0.7.0 changed the declaration order of MakeCheckOpValueString in logging.h.
# The function is called at line 710-711 before its template definition at line ~753.
# Fix: create an overlay glog/logging.h with forward declaration and use include_next.
# Then patch folly's CMakeLists.txt to inject this overlay before other includes.
mkdir -p _glog_overlay/glog
cat > _glog_overlay/glog/logging.h << 'HDREOF'
#pragma once
// Forward declare MakeCheckOpValueString before including real glog/logging.h
// This fixes glog 0.7.0 declaration order issue
#include <ostream>
#include <string>

template <typename T>
inline void MakeCheckOpValueString(std::ostream* os, const T& v) {
    (*os) << v;
}

// Now include the real header via include_next
#include_next <glog/logging.h>
HDREOF

# Patch CMakeLists.txt to add the overlay include directory BEFORE all other includes.
# This ensures our glog/logging.h intercepts glog includes.
sed -i '/^project(/a include_directories(BEFORE SYSTEM "${CMAKE_SOURCE_DIR}/_glog_overlay")' CMakeLists.txt || true
"""],
)
