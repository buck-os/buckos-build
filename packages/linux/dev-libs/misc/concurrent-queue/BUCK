load("//defs:package.bzl", "package")

# concurrent-queue - Thread-safe queue for C++

package(
    build_rule = "binary",
    name = "concurrent-queue",
    version = "main",
    url = "https://github.com/davidstone/concurrent-queue/archive/bc638312d01655e9a1659078f8df8ad4d1c72f48.tar.gz",
    sha256 = "0dcbf8faa92e6a8cbddd4b3a58e8e32c24e48b927323ab69158d13bb348b0f29",
    description = "A fast multi-producer, multi-consumer lock-based concurrent queue",
    homepage = "https://github.com/davidstone/concurrent-queue",
    license = "BSL-1.0",
    deps = [],
    src_install = """
mkdir -p $INSTALL_DIR/usr/include
cp -r include/* $INSTALL_DIR/usr/include/ 2>/dev/null || find . -name '*.hpp' -exec cp {} $INSTALL_DIR/usr/include/ \\; 2>/dev/null || true
""",
)
