load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "fmt",
    version = "10.2.1",
    url = "https://github.com/fmtlib/fmt/archive/refs/tags/10.2.1.tar.gz",
    sha256 = "1250e4cc58bf06ee631567523f48848dc4596133e163f02615c97f78bab6c811",
    description = "Modern formatting library for C++",
    homepage = "https://fmt.dev/",
    license = "MIT",
    configure_args = [
        "-DBUILD_SHARED_LIBS=OFF",
        "-DFMT_TEST=OFF",
        "-DFMT_DOC=OFF",
    ],
    # fmt is in _TOOL_BLOCKLIST (ccache dep, prevents cycle), so
    # cmake/ninja aren't auto-injected — declare them explicitly.
    host_deps = [
        "//packages/linux/dev-tools/build-systems/cmake:cmake",
        "//packages/linux/dev-tools/build-systems/ninja:ninja",
    ],
    # CMake hardcodes absolute paths in the .pc file (exec_prefix=/usr,
    # libdir=/usr/lib64) instead of using variable references.  This breaks
    # pkg-config --define-prefix in cross-compilation.
    post_install_cmds = ["""
        for pc in "$DESTDIR"/usr/lib64/pkgconfig/*.pc "$DESTDIR"/usr/lib/pkgconfig/*.pc; do
            [ -f "$pc" ] || continue
            sed -i \
                -e 's|^exec_prefix=/usr$|exec_prefix=${prefix}|' \
                -e 's|^libdir=/usr/lib64$|libdir=${exec_prefix}/lib64|' \
                -e 's|^libdir=/usr/lib$|libdir=${exec_prefix}/lib|' \
                -e 's|^includedir=/usr/include$|includedir=${prefix}/include|' \
                "$pc"
        done
    """],
)
