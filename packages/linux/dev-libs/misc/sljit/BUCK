load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "sljit",
    version = "0.0.20250107",
    url = "https://github.com/zherczeg/sljit/archive/7779da89dc7e00a540712fcb859b762d4eca2a26.tar.gz",
    sha256 = "9e86bb4c12e00f37383a391e8f2614adc4c092fcb7f45753b9c548669b310586",
    description = "Platform-independent low-level JIT compiler",
    homepage = "https://zherczeg.github.io/sljit/",
    license = "BSD-2-Clause",
    deps = [],
    # sljit is a single-file library; install the headers
    install_script = """
mkdir -p "$OUT/usr/include/sljit"
cp sljit_src/*.h "$OUT/usr/include/sljit/"
cp sljit_src/sljitLir.c "$OUT/usr/include/sljit/"
""",
)
