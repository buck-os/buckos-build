load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "dto",
    version = "1.0",
    url = "https://github.com/intel/dto/archive/refs/tags/v1.0.tar.gz",
    sha256 = "916e6a173fa76140551ceb830be3ad9d58b4ee2656edce1a9bf5d26c29db3e1a",
    description = "Intel Data Transfer Optimizer library for DSA acceleration",
    homepage = "https://github.com/intel/dto",
    license = "MIT",
    install_script = """
        cd $SRCS

        # Create a stub accel-config header so the source compiles
        mkdir -p _stubs/accel-config
        cat > _stubs/accel-config/libaccel_config.h << 'STUBEOF'
#ifndef _LIBACCEL_CONFIG_H_
#define _LIBACCEL_CONFIG_H_
/* Stub for accel-config - DSA hardware not available */
struct accfg_ctx;
struct accfg_wq;
static inline int accfg_new(struct accfg_ctx **ctx) { (void)ctx; return -1; }
static inline void accfg_unref(struct accfg_ctx *ctx) { (void)ctx; }
enum accfg_wq_state { ACCFG_WQ_DISABLED = 0, ACCFG_WQ_ENABLED = 1 };
enum accfg_wq_mode { ACCFG_WQ_SHARED = 0, ACCFG_WQ_DEDICATED = 1 };
enum accfg_wq_type { ACCFG_WQT_NONE = 0, ACCFG_WQT_KERNEL = 1, ACCFG_WQT_USER = 2 };
enum accfg_device_state { ACCFG_DEVICE_DISABLED = 0, ACCFG_DEVICE_ENABLED = 1 };
struct accfg_device;
struct accfg_group;
static inline struct accfg_device *accfg_device_get_first(struct accfg_ctx *c) { (void)c; return (void*)0; }
static inline struct accfg_device *accfg_device_get_next(struct accfg_device *d) { (void)d; return (void*)0; }
static inline enum accfg_device_state accfg_device_get_state(struct accfg_device *d) { (void)d; return ACCFG_DEVICE_DISABLED; }
static inline int accfg_device_get_version(struct accfg_device *d) { (void)d; return 0; }
static inline const char *accfg_device_get_devname(struct accfg_device *d) { (void)d; return ""; }
static inline int accfg_device_get_id(struct accfg_device *d) { (void)d; return -1; }
static inline struct accfg_wq *accfg_wq_get_first(struct accfg_device *d) { (void)d; return (void*)0; }
static inline struct accfg_wq *accfg_wq_get_next(struct accfg_wq *w) { (void)w; return (void*)0; }
static inline enum accfg_wq_state accfg_wq_get_state(struct accfg_wq *w) { (void)w; return ACCFG_WQ_DISABLED; }
static inline enum accfg_wq_mode accfg_wq_get_mode(struct accfg_wq *w) { (void)w; return ACCFG_WQ_SHARED; }
static inline const char *accfg_wq_get_devname(struct accfg_wq *w) { (void)w; return ""; }
static inline int accfg_wq_get_id(struct accfg_wq *w) { (void)w; return -1; }
static inline int accfg_wq_get_group_id(struct accfg_wq *w) { (void)w; return -1; }
static inline int accfg_wq_get_size(struct accfg_wq *w) { (void)w; return 0; }
static inline int accfg_wq_get_max_batch_size(struct accfg_wq *w) { (void)w; return 0; }
static inline int accfg_wq_get_max_transfer_size(struct accfg_wq *w) { (void)w; return 0; }
static inline enum accfg_wq_type accfg_wq_get_type(struct accfg_wq *w) { (void)w; return ACCFG_WQT_NONE; }
static inline const char *accfg_wq_get_user_dev_path(struct accfg_wq *w) { (void)w; return ""; }
static inline unsigned long long accfg_device_get_gen_cap(struct accfg_device *d) { (void)d; return 0; }
/* foreach macros */
#define accfg_device_foreach(ctx, dev) for (dev = accfg_device_get_first(ctx); dev; dev = accfg_device_get_next(dev))
#define accfg_wq_foreach(dev, wq) for (wq = accfg_wq_get_first(dev); wq; wq = accfg_wq_get_next(wq))
#endif
STUBEOF

        # Add missing includes and _GNU_SOURCE at the top of dto.c
        sed -i '1i #define _GNU_SOURCE' dto.c 2>/dev/null || true
        sed -i '2i #include <limits.h>' dto.c 2>/dev/null || true
        sed -i '3i #include <stdarg.h>' dto.c 2>/dev/null || true
        sed -i '4i #include <unistd.h>' dto.c 2>/dev/null || true
        sed -i '5i #include <time.h>' dto.c 2>/dev/null || true

        # Build the shared library with the stub header
        $CC -shared -fPIC -Wl,-soname,libdto.so \
            $CFLAGS $LDFLAGS \
            -I_stubs \
            dto.c \
            -D_GNU_SOURCE \
            -DDTO_STATS_SUPPORT \
            -Wno-error \
            -o libdto.so.1.0 \
            -ldl -lnuma

        # Install library
        mkdir -p $OUT/usr/lib64
        cp libdto.so.1.0 $OUT/usr/lib64/
        ln -sf libdto.so.1.0 $OUT/usr/lib64/libdto.so.1
        ln -sf libdto.so.1.0 $OUT/usr/lib64/libdto.so

        # Install header
        mkdir -p $OUT/usr/include
        cp dto.h $OUT/usr/include/ 2>/dev/null || true
    """,
    deps = [
        "//packages/linux/system/libs/numactl:numactl",
    ],
)
