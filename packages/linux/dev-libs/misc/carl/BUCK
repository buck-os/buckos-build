load("//defs:package.bzl", "package")

# CARL - Classical Action Recognition Library
# A C++ library for generalized action recognition in XR applications

package(
    build_rule = "cmake",
    name = "carl",
    version = "0.1.0",
    url = "https://github.com/facebookexperimental/carl/archive/2b39b96f4f4fb1301faabaabb45d4d9ee166dbad.tar.gz",
    sha256 = "ae910e38610b04817fcab897796fddf0bcdbfb3ececc90ffeb7d94a96f2327cb",
    description = "Classical Action Recognition Library for gesture recognition in XR applications",
    homepage = "https://github.com/facebookexperimental/carl",
    license = "MIT",
    deps = [
        "//packages/linux/dev-libs/eigen:eigen",
        "//packages/linux/dev-libs/misc/arcana-cpp:arcana-cpp",
    ],
    pre_configure_cmds = ["""
# The Dependencies/CMakeLists.txt expects bundled eigen as a git submodule.
# Patch it to use system Eigen instead.
cat > Dependencies/CMakeLists.txt << 'DEPSEOF'
cmake_minimum_required(VERSION 3.13)
find_package(Eigen3 REQUIRED)
DEPSEOF
"""],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_CXX_STANDARD=17",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TESTING=OFF",
        "-DBUILD_EXAMPLES=OFF",
    ],
)
