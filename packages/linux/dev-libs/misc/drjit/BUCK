load("//defs:package.bzl", "package")

# Dr.Jit - A Just-In-Time-Compiler for Differentiable Rendering

package(
    build_rule = "cmake",
    name = "drjit",
    version = "1.2.0",
    url = "https://github.com/mitsuba-renderer/drjit/archive/refs/tags/v1.2.0.tar.gz",
    sha256 = "8f7ae4fd6ffc826c3430c2cfc4243bd610fe86537b22a7608cf5481d7286b86d",
    description = "Just-in-time compiler for differentiable rendering and numerical computation",
    homepage = "https://github.com/mitsuba-renderer/drjit",
    license = "BSD-3-Clause",
    deps = [],
    pre_configure_cmds = ["""
# Create stub directories for required submodules
mkdir -p ext/drjit-core/ext/nanothread/include/nanothread
mkdir -p ext/drjit-core/ext/robin_map/include/tsl
mkdir -p ext/drjit-core/include/drjit-core

# Create minimal nanothread CMakeLists
cat > ext/drjit-core/ext/nanothread/CMakeLists.txt << 'NEOF'
cmake_minimum_required(VERSION 3.13)
project(nanothread)
add_library(nanothread INTERFACE)
target_include_directories(nanothread INTERFACE include)
NEOF
# Minimal nanothread header
cat > ext/drjit-core/ext/nanothread/include/nanothread/nanothread.h << 'NHEOF'
#pragma once
NHEOF

# Create minimal robin_map CMakeLists
cat > ext/drjit-core/ext/robin_map/CMakeLists.txt << 'REOF'
cmake_minimum_required(VERSION 3.13)
project(robin_map)
add_library(tsl-robin-map INTERFACE)
target_include_directories(tsl-robin-map INTERFACE include)
add_library(tsl::robin_map ALIAS tsl-robin-map)
REOF

# Create minimal drjit-core CMakeLists
cat > ext/drjit-core/CMakeLists.txt << 'DCEOF'
cmake_minimum_required(VERSION 3.13)
project(drjit-core LANGUAGES CXX)
add_subdirectory(ext/nanothread)
add_subdirectory(ext/robin_map)
add_library(drjit-core INTERFACE)
target_include_directories(drjit-core INTERFACE include)
target_link_libraries(drjit-core INTERFACE nanothread)
DCEOF

# Create minimal drjit-core header
cat > ext/drjit-core/include/drjit-core/jit.h << 'JHEOF'
#pragma once
JHEOF

# Remove the entire submodule check block that causes CMake parse errors
# The block contains a quoted multi-line string that CMake can't parse without the submodule
python3 -c "
import re
with open('CMakeLists.txt', 'r') as f:
    content = f.read()
# Remove the if(NOT EXISTS ...) block that checks for submodules
content = re.sub(r'if\s*\(NOT EXISTS[^)]*drjit-core[^)]*\).*?endif\(\)', '', content, flags=re.DOTALL)
# Also remove any standalone FATAL_ERROR about submodules
content = re.sub(r'message\(FATAL_ERROR[^)]*clone[^)]*\)', 'message(STATUS \"Using stubs\")', content)
with open('CMakeLists.txt', 'w') as f:
    f.write(content)
"
"""],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_CXX_STANDARD=17",
        "-DDRJIT_ENABLE_TESTS=OFF",
        "-DDRJIT_ENABLE_PYTHON=OFF",
        "-DDRJIT_ENABLE_LLVM=OFF",
        "-DDRJIT_ENABLE_CUDA=OFF",
        "-DDRJIT_ENABLE_AUTODIFF=ON",
    ],
)
