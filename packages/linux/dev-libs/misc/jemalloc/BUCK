load("//defs:package_defs.bzl", "autotools_package")

# jemalloc - General purpose memory allocator

autotools_package(
    name = "jemalloc",
    version = "5.3.0",
    src_uri = "https://github.com/jemalloc/jemalloc/releases/download/5.3.0/jemalloc-5.3.0.tar.bz2",
    sha256 = "2db82d1e7119df3e71b7640219b6dfe84789bc0537983c3b7ac4f7189aecfeaa",
    description = "General purpose memory allocator with scalable concurrency support",
    homepage = "https://jemalloc.net/",
    license = "BSD-2-Clause",
    iuse = ["stats", "prof"],
    use_defaults = ["stats"],
    deps = [],
    configure_args = [
        "--prefix=${PREFIX}",
        "--enable-shared",
        "--disable-static",
    ],
    use_configure = {
        "stats": "--enable-stats",
        "-stats": "--disable-stats",
        "prof": "--enable-prof",
        "-prof": "--disable-prof",
    },
    visibility = ["PUBLIC"],
)
