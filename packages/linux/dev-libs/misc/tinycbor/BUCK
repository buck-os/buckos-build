load("//defs:package.bzl", "package")

# tinycbor - Concise Binary Object Representation (CBOR) Library

package(
    build_rule = "binary",
    name = "tinycbor",
    version = "0.6.0",
    url = "https://github.com/intel/tinycbor/archive/refs/tags/v0.6.0.tar.gz",
    sha256 = "512e2c9fce74f60ef9ed3af59161e905f9e19f30a52e433fc55f39f4c70d27e4",
    description = "Concise Binary Object Representation (CBOR) Library",
    homepage = "https://github.com/intel/tinycbor",
    license = "MIT",
    deps = [],
    install_script = """
cd "$SRCS"

make -j${MAKEOPTS:-$(nproc)} CC="$CC" AR="$AR" \
    CFLAGS="$CFLAGS" LDFLAGS="$LDFLAGS"

make prefix=/usr DESTDIR=$OUT install
""",
)
