load("//defs:package_defs.bzl", "cmake_package")

# date - Howard Hinnant's date and time library for C++

cmake_package(
    name = "date",
    version = "3.0.1",
    src_uri = "https://github.com/HowardHinnant/date/archive/refs/tags/v3.0.1.tar.gz",
    sha256 = "TODO",
    description = "Howard Hinnant's date and time library for C++",
    homepage = "https://github.com/HowardHinnant/date",
    license = "MIT",
    iuse = ["tz"],
    use_defaults = [],
    deps = [],
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TZ_LIB=OFF",
        "-DUSE_SYSTEM_TZ_DB=ON",
        "-DENABLE_DATE_TESTING=OFF",
    ],
    use_cmake = {
        "tz": "-DBUILD_TZ_LIB=ON",
        "-tz": "-DBUILD_TZ_LIB=OFF",
    },
    visibility = ["PUBLIC"],
)
