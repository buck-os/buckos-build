load("//defs:package.bzl", "package")

# xtensor - C++ tensors with broadcasting and lazy computing

package(
    build_rule = "binary",
    name = "xtensor",
    version = "0.24.7",
    url = "https://github.com/xtensor-stack/xtensor/archive/refs/tags/0.24.7.tar.gz",
    sha256 = "0fbbd524dde2199b731b6af99b16063780de6cf1d0d6cb1f3f4d4ceb318f3106",
    description = "C++ tensors with broadcasting and lazy computing",
    homepage = "https://xtensor.readthedocs.io/",
    license = "BSD-3-Clause",
    deps = [],
    install_script = """
mkdir -p "$OUT/usr/include"
cp -a include/xtensor "$OUT/usr/include/"
""",
)
