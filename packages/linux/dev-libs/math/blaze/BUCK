load("//defs:package.bzl", "package")

# Blaze - High performance C++ math library

package(
    build_rule = "binary",
    name = "blaze",
    version = "3.8.2",
    url = "https://bitbucket.org/blaze-lib/blaze/downloads/blaze-3.8.2.tar.gz",
    sha256 = "4c4e1915971efbedab95790e4c5cf017d8448057fa8f8c62c46e1643bf72cbb1",
    description = "High performance C++ math library for dense and sparse arithmetic",
    homepage = "https://bitbucket.org/blaze-lib/blaze",
    license = "BSD-3-Clause",
    deps = [],
    src_install = """
mkdir -p $INSTALL_DIR/usr/include
cp -r blaze $INSTALL_DIR/usr/include/
""",
)
