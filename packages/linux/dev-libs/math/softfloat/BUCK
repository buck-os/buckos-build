load("//defs:package_defs.bzl", "download_source", "ebuild_package")

download_source(
    name = "softfloat-src",
    src_uri = "http://www.jhauser.us/arithmetic/SoftFloat-3e.zip",
    sha256 = "21130ce885d35c1fe73fc1e1bf2244178167e05c6747cad5f450cc991714c746",
)

ebuild_package(
    name = "softfloat",
    version = "3e",
    source = ":softfloat-src",
    src_configure = ":",
    src_compile = """
        cd build/Linux-x86_64-GCC
        make SOURCE_DIR=../../source COMPILE_C="$CC -c -fPIC -Werror-implicit-function-declaration -DSOFTFLOAT_FAST_INT64 -DSOFTFLOAT_ROUND_ODD -DINLINE_LEVEL=5 -DSOFTFLOAT_FAST_DIV32TO16 -DSOFTFLOAT_FAST_DIV64TO32 -I. -I../../source/8086-SSE -I../../source/include $CFLAGS -o"
    """,
    src_install = """
        mkdir -p $D/usr/lib $D/usr/include/softfloat
        cp build/Linux-x86_64-GCC/softfloat.a $D/usr/lib/libsoftfloat.a
        cp source/include/*.h $D/usr/include/softfloat/
    """,
    visibility = ["PUBLIC"],
)
