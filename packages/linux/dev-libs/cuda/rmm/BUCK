load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "rmm",
    version = "24.12.00",
    url = "https://github.com/rapidsai/rmm/archive/refs/tags/v24.12.00.tar.gz",
    sha256 = "4a48e86a9ae9997b79b2d0708a58929fa61cb138a75064293ff77bed2dc21938",
    description = "RAPIDS Memory Manager - CUDA memory allocation library",
    homepage = "https://github.com/rapidsai/rmm",
    license = "Apache-2.0",
    install_script = """
cd "$SRCS"

# RMM is a header-only C++ library (requires CUDA at runtime).
# Install headers and cmake config without building (no rapids-cmake available).
mkdir -p "$OUT/usr/include"
cp -r include/rmm "$OUT/usr/include/"

# Install cmake config
mkdir -p "$OUT/usr/lib/cmake/rmm"
cat > "$OUT/usr/lib/cmake/rmm/rmm-config.cmake" << 'CMAKEOF'
# RMM header-only package config
if(NOT TARGET rmm::rmm)
    add_library(rmm::rmm INTERFACE IMPORTED)
    set_target_properties(rmm::rmm PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${CMAKE_CURRENT_LIST_DIR}/../../../include"
    )
endif()
CMAKEOF
""",
    deps = [
        "//packages/linux/dev-libs/misc/fmt:fmt",
        "//packages/linux/dev-libs/logging/spdlog:spdlog",
        "//packages/linux/dev-libs/cuda/nvtx:nvtx",
    ],
    labels = ["buckos:hw:cuda"],
)
