load("//defs:package.bzl", "package")

# cuCollections - GPU-accelerated concurrent data structures
# Header-only library providing GPU-accelerated data structures similar to STL

package(
    build_rule = "binary",
    name = "cucollections",
    version = "0.0.1",
    url = "https://github.com/NVIDIA/cuCollections/archive/a4fb98500fc29401983e7d668c2ba12a5c86e7bf.tar.gz",
    sha256 = "794db0e37f184376fee352d93bbc42422601babc71291904f2595265e8036e1b",

    deps = [],

    install_script = """
# Header-only CUDA library - install include directory
mkdir -p "$OUT/usr/include"
cp -r "$SRCS/include/"* "$OUT/usr/include/" 2>/dev/null || true
echo "cucollections headers installed successfully"
""",

    labels = ["buckos:hw:cuda"],
)
