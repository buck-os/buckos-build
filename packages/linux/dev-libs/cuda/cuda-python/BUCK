load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "cuda-python",
    version = "12.9.0",
    url = "https://files.pythonhosted.org/packages/24/3c/4475aebeaab9651f2e61000fbe76f91a476d371dbfbf0a1cf46e689af253/cuda_python-12.9.0-py3-none-any.whl",
    sha256 = "926acba49b2c0a0374c61b7c98f337c085199cf51cdfe4d6423c4129c20547a7",
    format = "zip",
    strip_components = 0,
    deps = [
        "//packages/linux/lang/python:python",
    ],

    install_script = """
# Install pre-built Python wheel contents
SITE_DIR="$OUT/usr/lib/python3/site-packages"
mkdir -p "$SITE_DIR"
# Copy all package directories from the extracted wheel
for d in "$SRCS"/cuda "$SRCS"/cuda_python*; do
    [ -e "$d" ] && cp -r "$d" "$SITE_DIR/" 2>/dev/null || true
done
echo "cuda-python installed successfully"
""",

    labels = ["buckos:hw:cuda"],
)
