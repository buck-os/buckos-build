load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "libb64",
    version = "2.0.0.1",
    url = "https://github.com/libb64/libb64/archive/refs/tags/v2.0.0.1.tar.gz",
    sha256 = "ce8e578a953a591bd4a6f157eec310b9a4c2e6f10ade2fdda6ae6bafaf798b98",
    description = "Base64 encoding/decoding library in C",
    homepage = "https://github.com/libb64/libb64",
    license = "CC0-1.0",
    deps = [],
    install_script = """
mkdir -p "$OUT/usr/lib64"
mkdir -p "$OUT/usr/include/b64"
$CC -c -O2 -fPIC -Iinclude src/cencode.c -o cencode.o
$CC -c -O2 -fPIC -Iinclude src/cdecode.c -o cdecode.o
$AR rcs "$OUT/usr/lib64/libb64.a" cencode.o cdecode.o
cp include/b64/*.h "$OUT/usr/include/b64/"
""",
)
