load("//defs:package.bzl", "package")

package(
    build_rule = "cmake",
    name = "jinja2cpp",
    version = "1.3.2",
    url = "https://github.com/jinja2cpp/Jinja2Cpp/archive/refs/tags/1.3.2.tar.gz",
    sha256 = "227afb9d16eb1a47c3f3ca10c2f589dd2791c5d8b4767c73e26a0b8997e4c03e",
    description = "Jinja2 C++ template engine implementation",
    homepage = "https://github.com/jinja2cpp/Jinja2Cpp",
    license = "MPL-2.0",
    deps = [
        "//packages/linux/dev-libs/boost:boost",
        "//packages/linux/dev-libs/misc/fmt:fmt",
        "//packages/linux/dev-libs/json/rapidjson:rapidjson",
    ],
    pre_configure_cmds = ["""
# Install expected-lite header locally for the external deps mode
mkdir -p _local_deps/include/nonstd
cat > _local_deps/include/nonstd/expected.hpp << 'EXPEOF'
#pragma once
#include <stdexcept>
#include <type_traits>
#include <utility>
namespace nonstd {
    template<typename T, typename E>
    class expected {
    public:
        expected() : m_has_value(true), m_value() {}
        expected(const T& v) : m_has_value(true), m_value(v) {}
        expected(T&& v) : m_has_value(true), m_value(std::move(v)) {}
        static expected from_error(const E& e) { expected r; r.m_has_value = false; r.m_error = e; return r; }
        bool has_value() const { return m_has_value; }
        explicit operator bool() const { return m_has_value; }
        T& value() { if (!m_has_value) throw std::logic_error("no value"); return m_value; }
        const T& value() const { if (!m_has_value) throw std::logic_error("no value"); return m_value; }
        T& operator*() { return m_value; }
        const T& operator*() const { return m_value; }
        T* operator->() { return &m_value; }
        const E& error() const { return m_error; }
    private:
        bool m_has_value;
        T m_value;
        E m_error;
    };
    using in_place_t = std::in_place_t;
    template<typename E>
    class unexpected {
    public:
        unexpected(const E& e) : m_error(e) {}
        const E& value() const { return m_error; }
    private:
        E m_error;
    };
    template<typename E>
    unexpected<E> make_unexpected(const E& e) { return unexpected<E>(e); }
}
EXPEOF
# Create a find module for expected-lite
mkdir -p _local_deps/cmake
cat > _local_deps/cmake/Findexpected-lite.cmake << 'FINDEOF'
set(expected-lite_FOUND TRUE)
set(expected-lite_INCLUDE_DIR "${CMAKE_CURRENT_LIST_DIR}/../include")
if(NOT TARGET expected-lite::expected-lite)
    add_library(expected-lite::expected-lite INTERFACE IMPORTED)
    set_target_properties(expected-lite::expected-lite PROPERTIES
        INTERFACE_INCLUDE_DIRECTORIES "${expected-lite_INCLUDE_DIR}")
endif()
FINDEOF
"""],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DJINJA2CPP_BUILD_TESTS=OFF",
        "-DJINJA2CPP_STRICT_WARNINGS=OFF",
        "-DJINJA2CPP_DEPS_MODE=external",
        "-DJINJA2CPP_WITH_JSON_BINDINGS=rapid",
        "-DJINJA2CPP_USE_REGEX=std",
        "-DJINJA2CPP_BUILD_SHARED=OFF",
        "-DJINJA2CPP_PIC=ON",
        "-DCMAKE_CXX_STANDARD=17",
        "-DCMAKE_MODULE_PATH=${CMAKE_CURRENT_SOURCE_DIR}/_local_deps/cmake",
    ],
)
