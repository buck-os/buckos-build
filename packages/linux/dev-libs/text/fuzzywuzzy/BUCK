load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "fuzzywuzzy",
    version = "0.0.1",
    url = "https://github.com/tmplt/fuzzywuzzy/archive/b62013235a15c484203b6ff6c369c813a284cf6e.tar.gz",
    sha256 = "ffd652e7e38c67ae581de1029b0e0db62eb5287990244bf25cb4e265959f864d",
    description = "C++ port of the Python fuzzywuzzy fuzzy string matching library",
    homepage = "https://github.com/tmplt/fuzzywuzzy",
    license = "MIT",
    install_script = """
mkdir -p $OUT/usr/include/fuzzywuzzy
cp include/fuzzywuzzy.hpp $OUT/usr/include/fuzzywuzzy/
""",
)
