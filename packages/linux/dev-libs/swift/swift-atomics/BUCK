load("//defs:package.bzl", "package")

package(
    build_rule = "binary",
    name = "swift-atomics",
    version = "1.0.2",
    url = "https://github.com/apple/swift-atomics/archive/refs/tags/1.0.2.tar.gz",
    sha256 = "c8b88186db4902dc5109340f4a745ea787cb2aa9533c7e6d1e634549f9e527b1",
    deps = [
        "//packages/linux/lang/swift:swift",
    ],

    install_script = """
# Swift package - install source files for Swift Package Manager consumption
mkdir -p "$OUT/usr/lib/swift/swift-atomics"
cp -r "$SRCS/Sources/"* "$OUT/usr/lib/swift/swift-atomics/" 2>/dev/null || true
echo "swift-atomics sources installed successfully"
""",
)
