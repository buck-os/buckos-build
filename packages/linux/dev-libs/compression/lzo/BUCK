load("//defs:package_defs.bzl", "autotools_package")

# LZO - Portable lossless data compression library

autotools_package(
    name = "lzo",
    version = "2.10",
    src_uri = "https://www.oberhumer.com/opensource/lzo/download/lzo-2.10.tar.gz",
    sha256 = "c0f892943208266f9b6543b3ae308fab6284c5c90e627931446fb49b4221a072",
    description = "Portable lossless data compression library written in ANSI C",
    homepage = "https://www.oberhumer.com/opensource/lzo/",
    license = "GPL-2.0-or-later",
    iuse = ["asm"],
    use_defaults = ["asm"],
    deps = [],
    configure_args = [
        "--prefix=${PREFIX}",
        "--enable-shared",
        "--disable-static",
    ],
    use_configure = {
        "asm": "--enable-asm",
        "-asm": "--disable-asm",
    },
    visibility = ["PUBLIC"],
)
