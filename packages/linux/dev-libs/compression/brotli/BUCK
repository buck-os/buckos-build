load("//defs:package_defs.bzl", "cmake_package")

# Brotli - Generic-purpose lossless compression algorithm

cmake_package(
    name = "brotli",
    version = "1.1.0",
    src_uri = "https://github.com/google/brotli/archive/refs/tags/v1.1.0.tar.gz",
    sha256 = "TODO",
    description = "Brotli compression format from Google",
    homepage = "https://github.com/google/brotli",
    license = "MIT",
    iuse = ["cli"],
    use_defaults = ["cli"],
    deps = [],
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBROTLI_DISABLE_TESTS=ON",
        "-DBROTLI_BUNDLED_MODE=OFF",
    ],
    use_cmake = {
        "cli": "-DBROTLI_BUILD_TOOLS=ON",
        "-cli": "-DBROTLI_BUILD_TOOLS=OFF",
    },
    visibility = ["PUBLIC"],
)
