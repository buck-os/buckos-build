load("//defs:package.bzl", "package")

package(
    name = "cborg",
    build_rule = "binary",
    version = "1.0.3",
    url = "https://github.com/TRUEPIC/cborg/archive/refs/tags/v1.0.3.tar.gz",
    sha256 = "9ee5cdd690f99bd002acf949a1eb21af9a1e1560ef3a2faa5913b49aaf92a67f",
    description = "A simple CBOR encoder/decoder with a fluent API",
    homepage = "https://github.com/truepic/cborg",
    license = "Apache-2.0",
    deps = [],
    install_script = """
mkdir -p "$OUT/usr/include/cborg"
mkdir -p "$OUT/usr/lib64"
cp cborg/*.h "$OUT/usr/include/cborg/"
$CXX -c -O2 -fPIC -fstack-protector-strong -I. source/CborBase.cpp -o CborBase.o
$CXX -c -O2 -fPIC -fstack-protector-strong -I. source/Cbore.cpp -o Cbore.o
$CXX -c -O2 -fPIC -fstack-protector-strong -I. source/Cborg.cpp -o Cborg.o
$AR rcs "$OUT/usr/lib64/libcborg.a" CborBase.o Cbore.o Cborg.o
""",
)
