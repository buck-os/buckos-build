load("//defs:package_defs.bzl", "cmake_package")

# Protocol Buffers - Google's language-neutral data serialization

cmake_package(
    name = "protobuf",
    version = "25.1",
    src_uri = "https://github.com/protocolbuffers/protobuf/releases/download/v25.1/protobuf-25.1.tar.gz",
    sha256 = "TODO",
    description = "Google's language-neutral, platform-neutral, extensible data serialization format",
    homepage = "https://protobuf.dev/",
    license = "BSD-3-Clause",
    iuse = ["lite", "python", "java"],
    deps = [
        "//packages/linux/core/zlib:zlib",
        "//packages/linux/dev-libs/misc/abseil-cpp:abseil-cpp",
    ],
    use_deps = {
        "python": ["//packages/linux/lang/python:python"],
    },
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-Dprotobuf_BUILD_TESTS=OFF",
        "-Dprotobuf_BUILD_EXAMPLES=OFF",
        "-Dprotobuf_ABSL_PROVIDER=package",
    ],
    use_cmake = {
        "lite": "-Dprotobuf_BUILD_LIBPROTOC=OFF",
        "-lite": "-Dprotobuf_BUILD_LIBPROTOC=ON",
    },
    visibility = ["PUBLIC"],
)
