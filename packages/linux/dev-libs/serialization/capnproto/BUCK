load("//defs:package_defs.bzl", "cmake_package")

# Cap'n Proto - Insanely fast data interchange format

cmake_package(
    name = "capnproto",
    version = "1.0.2",
    src_uri = "https://github.com/capnproto/capnproto/archive/refs/tags/v1.0.2.tar.gz",
    sha256 = "TODO",
    description = "Insanely fast data interchange format and RPC system",
    homepage = "https://capnproto.org/",
    license = "MIT",
    iuse = ["tls", "http"],
    use_defaults = ["tls"],
    deps = [
        "//packages/linux/core/zlib:zlib",
    ],
    use_deps = {
        "tls": ["//packages/linux/network/openssl:openssl"],
    },
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_TESTING=OFF",
    ],
    use_cmake = {
        "tls": "-DWITH_OPENSSL=ON",
        "-tls": "-DWITH_OPENSSL=OFF",
    },
    visibility = ["PUBLIC"],
)
