load("//defs:package_defs.bzl", "download_source", "ebuild_package")

NAME = "p4api"
VERSION = "22.1"

download_source(
    name = NAME + "-src",
    src_uri = "https://ftp.perforce.com/perforce/r22.1/bin.linux26x86_64/p4api.tgz",
    sha256 = "TODO",
)

ebuild_package(
    name = NAME,
    version = VERSION,
    srcs = [":" + NAME + "-src"],
    build_script = """
        # No build needed - precompiled libraries
        true
    """,
    install_script = """
        mkdir -p "$OUT/usr/include/p4"
        mkdir -p "$OUT/usr/lib64"

        # Install headers
        cp -r "$SRCS/include/p4"/* "$OUT/usr/include/p4/"

        # Install static libraries
        cp "$SRCS/lib"/*.a "$OUT/usr/lib64/"
    """,
    deps = [
        "//packages/linux/dev-libs/crypto/openssl:openssl",
    ],
    visibility = ["PUBLIC"],
)
