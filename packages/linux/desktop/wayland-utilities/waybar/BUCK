        "-Dtests=disabled",
        "-Dman-pages=disabled",
        "--wrap-mode=nofallback",
        # GCC 14+ warns about dangling references in spdlog/fmt headers
        "-Dwerror=false",
    ],
    # spdlog bundles fmt internally but waybar also uses system fmt.
    # Tell spdlog headers to use system fmt to avoid redefinition conflicts.
    # extra_cflags only sets CFLAGS (C); need CXXFLAGS for C++ project.
    extra_cflags = ["-DSPDLOG_FMT_EXTERNAL", "-DFMT_SHARED"],
    env = {"CXXFLAGS": "-DSPDLOG_FMT_EXTERNAL -DFMT_SHARED"},
