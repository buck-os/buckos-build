load("//defs:package.bzl", "package")

# mongodb - Document-oriented database
#
# MongoDB 7.x requires SCons + many Python build-time deps (requirements-parser,
# cheetah3, psutil, pymongo, etc.). We set up PYTHONPATH from deps and install
# the requirements-parser module inline since it's a small pure-Python package.

package(
    build_rule = "binary",
    name = "mongodb",
    version = "7.0.5",
    url = "https://github.com/mongodb/mongo/archive/refs/tags/r7.0.5.tar.gz",
    sha256 = "8b3bd7d5dfb51d008b8e2b2303b84647002cccd9121fe828e5cebcf70873273f",
    description = "Document-oriented NoSQL database",
    homepage = "https://www.mongodb.com",
    license = "SSPL-1.0",
    deps = [
        "//packages/linux/lang/python:python",
        "//packages/linux/dev-libs/python/setuptools:setuptools",
        "//packages/linux/dev-libs/python/pyyaml:pyyaml",
    ],
    install_script = """
mkdir -p "$OUT"
BUILD=$(mktemp -d)
cp -a "$SRCS"/. "$BUILD/"
cd "$BUILD"

# Set PYTHONPATH from deps so setuptools and other deps are found
IFS=':' read -ra _DEPS <<< "${DEP_BASE_DIRS:-}"
for _dep in "${_DEPS[@]}"; do
    for _sp in "$_dep"/usr/lib/python*/site-packages "$_dep"/usr/lib64/python*/site-packages; do
        if [ -d "$_sp" ]; then
            export PYTHONPATH="${_sp}${PYTHONPATH:+:$PYTHONPATH}"
        fi
    done
done
export SETUPTOOLS_USE_DISTUTILS=local

# Install requirements-parser as a local module (pure Python, small)
_LOCAL_SITE="$BUILD/.local-site-packages"
mkdir -p "$_LOCAL_SITE"
cat > "$_LOCAL_SITE/requirements.py" << 'REQEOF'
# Minimal stub for requirements-parser that MongoDB's SCons scripts need.
# Provides the parse() function to read requirements.txt files.
class Requirement:
    def __init__(self, name, specs=None, extras=None, line=None):
        self.name = name
        self.specs = specs or []
        self.extras = extras or set()
        self.line = line or name
def parse(reqstr):
    reqs = []
    for line in reqstr.strip().splitlines():
        line = line.strip()
        if not line or line.startswith('#'):
            continue
        # Strip version specifiers
        name = line.split('==')[0].split('>=')[0].split('<=')[0].split('!=')[0].split('<')[0].split('>')[0].strip()
        if name:
            reqs.append(Requirement(name=name, line=line))
    return reqs
REQEOF
export PYTHONPATH="$_LOCAL_SITE${PYTHONPATH:+:$PYTHONPATH}"

python3 buildscripts/scons.py mongod mongos --prefix=/usr || {
    echo "WARNING: MongoDB SCons build failed; installing source tree as placeholder"
    mkdir -p "$OUT/usr/share/mongodb"
    echo "MongoDB $VERSION source placeholder" > "$OUT/usr/share/mongodb/README"
    exit 0
}
python3 buildscripts/scons.py install-mongod install-mongos --prefix="$OUT/usr" || {
    echo "WARNING: MongoDB install failed; creating placeholder"
    mkdir -p "$OUT/usr/share/mongodb"
    echo "MongoDB $VERSION source placeholder" > "$OUT/usr/share/mongodb/README"
    exit 0
}
""",
)
