+  vector<STR_VEC> csv_data;

   int c;
   const char *headerfile = NULL, *footerfile = NULL;
@@ -85,12 +85,12 @@ int main(int argc, char *argv[])
     {
       if(row.size() > 1)
       {
-        data.push_back(row);
+        csv_data.push_back(row);
       }
       row.erase(row.begin(), row.end());
     }
   }
-  if(data.size() == 0)
+  if(csv_data.size() == 0)
   {
     fprintf(stderr, "No data\n");
     return 1;
