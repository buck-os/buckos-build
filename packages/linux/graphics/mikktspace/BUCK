load("//defs:package.bzl", "package")

# MikkTSpace - Tangent Space Normal Maps library

package(
    build_rule = "cmake",
    name = "mikktspace",
    version = "1.0",
    url = "https://github.com/mmikk/MikkTSpace/archive/refs/heads/master.tar.gz",
    sha256 = "a07fb76cee5e5e08be84086462b9377b92cb369c878d953f32ca2e69b44cbd3b",
    description = "Tangent space calculation library for normal mapping",
    homepage = "https://github.com/mmikk/MikkTSpace",
    license = "Zlib",
    deps = [],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
    ],
    pre_configure_cmds = [
        """cat > CMakeLists.txt << 'CEOF'
cmake_minimum_required(VERSION 3.10)
project(mikktspace LANGUAGES C)
add_library(mikktspace SHARED mikktspace.c)
target_include_directories(mikktspace PUBLIC
    $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}>
    $<INSTALL_INTERFACE:include>
)
set_target_properties(mikktspace PROPERTIES PUBLIC_HEADER "mikktspace.h")
install(TARGETS mikktspace
    LIBRARY DESTINATION lib
    ARCHIVE DESTINATION lib
    PUBLIC_HEADER DESTINATION include
)
CEOF""",
    ],
)
