load("//defs:package_defs.bzl", "cmake_package")

# fx-gltf - A C++14/C++17 header-only library for simple, efficient, and robust glTF 2.0 importing
# From: https://github.com/jessey-git/fx-gltf
# Note: This uses the upstream git repository hash from fbsource/third-party/fx-gltf/METADATA.bzl

cmake_package(
    name = "fx-gltf",
    version = "2.0.0",
    src_uri = "https://github.com/jessey-git/fx-gltf/archive/7766c237ea81c0bb3759e78e5c0f22854843eef8.tar.gz",
    sha256 = "c0be2f39f1adad55dc0237ddbf93447ce8809a20707ef5f8c5f885400e74cb51",
    description = "A C++14/C++17 header-only library for simple, efficient, and robust glTF 2.0 importing",
    homepage = "https://github.com/jessey-git/fx-gltf",
    license = "MIT",
    maintainers = ["momentum_library"],
    deps = [
        "//packages/linux/dev-libs/json/nlohmann-json:nlohmann-json",
    ],
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
    ],
    # fx-gltf is a header-only library that doesn't include CMakeLists.txt
    # Create one to install the header file properly
    pre_configure = """
        # Create a minimal CMakeLists.txt for installing the header
        cat > CMakeLists.txt << 'EOF'
cmake_minimum_required(VERSION 3.14)
project(fx-gltf VERSION 2.0.0 LANGUAGES CXX)

# Header-only library - just install the header
install(FILES fx/gltf.h
        DESTINATION include/fx
        COMPONENT Development)

# Create a pkg-config file
set(prefix "\${CMAKE_INSTALL_PREFIX}")
set(exec_prefix "\${prefix}")
set(libdir "\${exec_prefix}/lib")
set(includedir "\${prefix}/include")
set(PACKAGE_VERSION "${PROJECT_VERSION}")

configure_file(
    "${CMAKE_CURRENT_SOURCE_DIR}/fx-gltf.pc.in"
    "${CMAKE_CURRENT_BINARY_DIR}/fx-gltf.pc"
    @ONLY
)

install(FILES "${CMAKE_CURRENT_BINARY_DIR}/fx-gltf.pc"
        DESTINATION lib/pkgconfig)
EOF

        # Create pkg-config template
        cat > fx-gltf.pc.in << 'EOF'
prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@

Name: fx-gltf
Description: A C++14/C++17 header-only library for glTF 2.0 importing
Version: @PACKAGE_VERSION@
Requires: nlohmann_json
Cflags: -I\${includedir}
EOF
    """,
    visibility = ["PUBLIC"],
)
