load("//defs:package.bzl", "package")

# OpenFBX - Lightweight FBX importer

package(
    build_rule = "cmake",
    name = "openfbx",
    version = "82a43d9",
    url = "https://github.com/nem0/OpenFBX/archive/82a43d9191f2250145fddc219b4083667c33f2a5.tar.gz",
    sha256 = "2cf64fd1d53157e58d37ec0253f829b3797ab07d86491888e27dfcff729c3f2d",
    description = "Lightweight open source FBX importer",
    homepage = "https://github.com/nem0/OpenFBX",
    license = "MIT",
    deps = [
        "//packages/linux/dev-libs/compression/libdeflate:libdeflate",
    ],
    configure_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_POSITION_INDEPENDENT_CODE=ON",
        "-DCMAKE_CXX_STANDARD=11",
    ],
    pre_configure_cmds = [
        """cat > CMakeLists.txt << 'CEOF'
cmake_minimum_required(VERSION 3.11)
project(OpenFBX LANGUAGES CXX)
set(CMAKE_CXX_STANDARD 11)
include(GNUInstallDirs)
find_library(DEFLATE_LIB NAMES deflate)
find_path(DEFLATE_INCLUDE NAMES libdeflate.h)
add_library(OpenFBX src/ofbx.cpp)
target_include_directories(OpenFBX PUBLIC
    $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/src>
    $<INSTALL_INTERFACE:${CMAKE_INSTALL_INCLUDEDIR}>
    PRIVATE ${DEFLATE_INCLUDE}
)
target_link_libraries(OpenFBX PRIVATE ${DEFLATE_LIB})
target_compile_definitions(OpenFBX PRIVATE _LARGEFILE64_SOURCE)
set_target_properties(OpenFBX PROPERTIES POSITION_INDEPENDENT_CODE ON)
install(TARGETS OpenFBX LIBRARY DESTINATION lib ARCHIVE DESTINATION lib)
install(FILES src/ofbx.h DESTINATION ${CMAKE_INSTALL_INCLUDEDIR})
CEOF""",
    ],
)
