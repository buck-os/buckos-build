    license = "BSD-3-Clause",
    maintainers = ["body_tracking"],
    iuse = ["openmp", "mpi", "hdf5", "cuda", "examples", "tests", "doc"],
    use_defaults = ["openmp"],
    deps = [],
    use_deps = {
