            # "//packages/linux/dev-libs/boost:boost",
        ],
        "cuda": [
            # CUDA dependency would go here when available
            # "//packages/linux/dev-libs/cuda:cuda",
        ],
        "tests": [
            # GTest dependency would go here when available
            # "//packages/linux/dev-libs/testing/gtest:gtest",
        ],
    },
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DBUILD_C_BINDINGS=ON",
        "-DBUILD_PYTHON_BINDINGS=OFF",
        "-DBUILD_MATLAB_BINDINGS=OFF",
        "-DBUILD_EXAMPLES=OFF",
        "-DBUILD_TESTS=OFF",
        "-DBUILD_DOC=OFF",
        "-DBUILD_CUDA_LIB=OFF",
        "-DUSE_OPENMP=OFF",
        "-DUSE_MPI=OFF",
    ],
    use_options = {
