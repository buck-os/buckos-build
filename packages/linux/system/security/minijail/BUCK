load("//defs:package_defs.bzl", "download_source", "ebuild_package")

download_source(
    name = "minijail-src",
    src_uri = "https://chromium.googlesource.com/chromiumos/platform/minijail/+archive/bfd22f25fd2302fe4ae5121d80c836e0f124e742.tar.gz",
    sha256 = "TODO",
    signature_required = False,
    strip_components = 0,
)

ebuild_package(
    name = "minijail",
    source = ":minijail-src",
    version = "19",
    category = "system/security",
    slot = "0",
    description = "Process sandboxing and containment library and tools",
    homepage = "https://chromium.googlesource.com/chromiumos/platform/minijail",
    license = "BSD-3-Clause",

    deps = [
        "//packages/linux/system/libs/ipc/libcap",
    ],

    src_configure = '''
# No configure step - Makefile-based build
true
''',

    src_compile = '''
# Generate syscall and constant tables
CC="${CC:-gcc}" ./gen_constants.sh libconstants.gen.c
CC="${CC:-gcc}" ./gen_syscalls.sh libsyscalls.gen.c

# Build minijail library and binary
make -j$(nproc) \\
    CC="${CC:-gcc}" \\
    CFLAGS="${CFLAGS}" \\
    LDFLAGS="${LDFLAGS}" \\
    LIBDIR=/usr/lib \\
    BINDMOUNT_ALLOWED_PREFIXES="/dev,/sys" \\
    ALLOW_DEBUG_LOGGING=yes \\
    libminijail.so minijail0
''',

    src_install = '''
# Install library
install -D -m 0755 libminijail.so "$DESTDIR/usr/lib/libminijail.so"
install -D -m 0644 libminijail.h "$DESTDIR/usr/include/libminijail.h"

# Install binary
install -D -m 0755 minijail0 "$DESTDIR/usr/bin/minijail0"
''',

    visibility = ["PUBLIC"],
)
