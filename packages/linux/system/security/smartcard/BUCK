load("//defs:package_defs.bzl", "download_source", "autotools_package")

# libpcsclite-headers - PC/SC Lite headers for smart card development
# This is a header-only package providing the development headers for
# building software that uses PC/SC Lite smart card APIs

download_source(
    name = "libpcsclite-headers-src",
    src_uri = "https://pcsclite.apdu.fr/files/pcsc-lite-2.0.3.tar.bz2",
    sha256 = "f42ee9efa489e9ff5d328baefa26f9c515be65021856e78d99ad1f0ead9ec85d",
    signature_required = False,
)

autotools_package(
    name = "libpcsclite-headers",
    source = ":libpcsclite-headers-src",
    version = "2.0.3",
    description = "PC/SC Lite development headers for smart card applications",
    homepage = "https://pcsclite.apdu.fr/",
    license = "BSD-3-Clause",
    pre_configure = """
        # Skip configure - we only need to install headers
        true
    """,
    configure_args = [],
    make_args = [],
    post_install = """
        # Install only the header files
        mkdir -p "$OUT/usr/include/PCSC"
        cp src/PCSC/*.h "$OUT/usr/include/PCSC/"
        # Also install to root include for compatibility
        mkdir -p "$OUT/usr/include"
        cp src/PCSC/pcsclite.h "$OUT/usr/include/"
        cp src/PCSC/winscard.h "$OUT/usr/include/"
        cp src/PCSC/wintypes.h "$OUT/usr/include/"
        cp src/PCSC/reader.h "$OUT/usr/include/"
        cp src/PCSC/ifdhandler.h "$OUT/usr/include/"
        cp src/PCSC/debuglog.h "$OUT/usr/include/" 2>/dev/null || true
    """,
    deps = [],
    visibility = ["PUBLIC"],
)
