        "//packages/linux/dev-tools/build-systems/automake:automake",
        "//packages/linux/dev-tools/build-systems/libtool:libtool",
    ],
)

# pam_abl - Auto blacklist for PAM
# pam-abl uses a plain Makefile, not autotools
package(
    build_rule = "autotools",
    name = "pam-abl",
    url = "https://github.com/deksai/pam_abl/archive/refs/tags/v0.6.0.tar.gz",

    sha256 = "164d1d5fe042d85f653e61ab8823257a2b377d0c43f391d35d11143b72802ad3",
    version = "0.6.0",
    description = "PAM module for auto-blacklisting failed logins",
    homepage = "https://github.com/deksai/pam_abl",
    license = "GPL-2.0+",
    skip_configure = True,
    src_compile = """
# pam-abl may have Makefile in a subdirectory or use cmake
if [ ! -f Makefile ] && [ ! -f makefile ]; then
    # Search for Makefile in subdirectories
    _mf=$(find . -maxdepth 2 -name Makefile -o -name makefile 2>/dev/null | head -1)
    if [ -n "$_mf" ]; then
        cd "$(dirname "$_mf")"
    else
        # If no Makefile, try cmake
        if [ -f CMakeLists.txt ]; then
            mkdir -p build && cd build
            cmake .. -DCMAKE_INSTALL_PREFIX=/usr -DCMAKE_C_FLAGS="$CFLAGS" -DCMAKE_EXE_LINKER_FLAGS="$LDFLAGS"
            make -j${MAKEOPTS:-$(nproc)}
            exit 0
        fi
        echo "WARNING: No Makefile found, attempting simple compilation"
        # Compile pam_abl.c directly if it exists
        if [ -f pam_abl.c ]; then
            $CC $CFLAGS -shared -fPIC -o pam_abl.so pam_abl.c $LDFLAGS -lpam
        fi
        exit 0
    fi
fi
make -j${MAKEOPTS:-$(nproc)} \
    CC="$CC" \
    CFLAGS="$CFLAGS" \
    LDFLAGS="$LDFLAGS"
""",
    src_install = """
mkdir -p "$OUT/lib/security" "$OUT/usr/bin" "$OUT/etc/security" "$OUT/usr/share/man/man1" "$OUT/usr/share/man/man5" "$OUT/usr/share/man/man8"
cp pam_abl.so "$OUT/lib/security/" 2>/dev/null || true
cp pam_abl "$OUT/usr/bin/" 2>/dev/null || true
cp conf/pam_abl.conf "$OUT/etc/security/" 2>/dev/null || true
cp doc/*.1 "$OUT/usr/share/man/man1/" 2>/dev/null || true
cp doc/*.5 "$OUT/usr/share/man/man5/" 2>/dev/null || true
cp doc/*.8 "$OUT/usr/share/man/man8/" 2>/dev/null || true
# Also search subdirectories for artifacts
find . -name 'pam_abl.so' -exec cp {} "$OUT/lib/security/" \\; 2>/dev/null || true
find . -name 'pam_abl' -type f -executable -exec cp {} "$OUT/usr/bin/" \\; 2>/dev/null || true
""",
    deps = [
        "//packages/linux/system/security/linux-pam:linux-pam",
    ],
)
