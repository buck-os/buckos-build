# pam_ssh_agent_auth - SSH agent-based authentication for sudo
# The old configure script fails "checking compiler and flags for sanity... no"
# in cross-compilation. Use cache variables to bypass broken checks.
package(
    build_rule = "autotools",
    name = "pam-ssh-agent-auth",
    url = "https://github.com/jbeverly/pam_ssh_agent_auth/archive/refs/tags/pam_ssh_agent_auth-0.10.4.tar.gz",

    sha256 = "9d440de6627940c09eadc342cc7d8bc9823654fd1a2be11c4f5820dd073054e0",
    version = "0.10.4",
    description = "PAM module for SSH agent-based authentication",
    homepage = "https://github.com/jbeverly/pam_ssh_agent_auth",
    license = "BSD-2-Clause",
    pre_configure_cmds = ["autoreconf -fi || autoreconf -i || true"],
    configure_args = [
        "--prefix=/usr",
        "--libexecdir=/lib/security",
        "--with-mantype=man",
        "--without-openssl-header-check",
    ],
    env = {
        "CFLAGS": "-Wno-error",
        # Bypass compiler sanity check that fails in cross-compilation
        "ac_cv_have_control_in_sendmsg": "yes",
        "ac_cv_have_broken_snprintf": "no",
        "ac_cv_func_strnvis": "no",
    },
    deps = [
        "//packages/linux/system/security/linux-pam:linux-pam",
        "//packages/linux/system/libs/crypto/openssl:openssl",
    ],
    host_deps = [
        "//packages/linux/dev-tools/build-systems/autoconf:autoconf",
        "//packages/linux/dev-tools/build-systems/automake:automake",
        "//packages/linux/dev-tools/build-systems/libtool:libtool",
    ],
)

