load("//defs/packages:autotools.bzl", "autotools_package")

# libbsd - BSD compatibility library for Linux
# Provides functions like strlcpy, strlcat, arc4random, etc.

autotools_package(
    name = "libbsd",
    version = "0.12.2",
    source = "//packages/linux/system/libs/bsd:libbsd-src",
    description = "BSD compatibility library for Linux",
    license = "BSD",

    configure_args = [
        "--disable-static",
    ],

    deps = [
        # libmd provides message digest functions used by libbsd
        "//packages/linux/system/libs/compat/libmd:libmd",
    ],

)
