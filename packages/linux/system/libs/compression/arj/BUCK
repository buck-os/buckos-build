load("//defs:package.bzl", "package")

# arj - ARJ archive utility
package(
    build_rule = "binary",
    name = "arj",
    url = "https://downloads.sourceforge.net/arj/arj-3.10.22.tar.gz",
    sha256 = "589e4c9bccc8669e7b6d8d6fcd64e01f6a2c21fe10aad56a83304ecc3b96a7db",
    version = "3.10.22",
    description = "Open-source ARJ archiver",
    homepage = "https://arj.sourceforge.net",
    license = "GPL-2",
    deps = [],
    install_script = """
cd "$SRCS"

# arj uses autotools in the gnu/ subdirectory
cd gnu
if [ -f configure.in ] && ! [ -f configure ]; then
    autoconf 2>/dev/null || true
fi
# Update config.sub and config.guess
for dir in /usr/share/automake-* /usr/share/automake /usr/share/misc /usr/share/gnuconfig; do
    if [ -f "$dir/config.sub" ] && [ -f "$dir/config.guess" ]; then
        cp -f "$dir/config.sub" config.sub 2>/dev/null || true
        cp -f "$dir/config.guess" config.guess 2>/dev/null || true
        chmod +x config.sub config.guess 2>/dev/null || true
        break
    fi
done
chmod +x configure 2>/dev/null || true
cd "$SRCS"

# Configure
cd gnu && ./configure && cd ..

# Try to build host tools to generate msg_arj.h
make prepare CC="${HOST_CC:-gcc}" CFLAGS="-Wno-error -Wno-implicit-function-declaration -Wno-implicit-int" LDFLAGS="" -j1 2>/dev/null || true

# If msg_arj.h still not generated, create a comprehensive stub
# IMPORTANT: M_ macros used in expressions like (errmsg==M_DISK_FULL||...)
# must be valid C expressions, NOT empty strings. Use unique negative ints.
_MSG_H=$(find . -name "msg_arj.h" -not -path '*/gnu/*' 2>/dev/null | head -1)
if [ -z "$_MSG_H" ]; then
    echo "Generating stub msg_arj.h from source references..."
    {
        echo '/* Auto-generated stub msg_arj.h for cross-compilation */'
        echo '#ifndef MSG_ARJ_INCLUDED'
        echo '#define MSG_ARJ_INCLUDED'
        # Extract all M_ identifiers referenced in source files
        # Use unique negative integer values so expressions like (x==M_FOO||...) parse correctly
        _counter=1
        grep -roh 'M_[A-Z_0-9]*' *.c *.h 2>/dev/null | sort -u | while read sym; do
            echo "#ifndef $sym"
            echo "#define $sym (-$_counter)"
            echo "#endif"
            _counter=$((_counter + 1))
        done
        echo '#endif'
    } > msg_arj.h
fi

# Fix fcloseall() - not available in modern glibc
sed -i 's/fcloseall()/0/g' arj.c 2>/dev/null || true

# Fix strnlen conflict with glibc - rename the local version
sed -i 's/static int strnlen/static int arj_strnlen/g; s/[^_]strnlen(/ arj_strnlen(/g' fardata.c 2>/dev/null || true

# Cross-compile
make CC="$CC" \
    CFLAGS="$CFLAGS -I. -Wno-error -Wno-implicit-function-declaration -Wno-implicit-int -Wno-int-conversion -Wno-incompatible-pointer-types" \
    LDFLAGS="$LDFLAGS" \
    -j${MAKEOPTS:-$(nproc)} || \
make CC="$CC" \
    CFLAGS="$CFLAGS -I. -Wno-error -Wno-implicit-function-declaration -Wno-implicit-int -Wno-int-conversion -Wno-incompatible-pointer-types" \
    LDFLAGS="$LDFLAGS" \
    -j1

# Install
mkdir -p "$OUT/usr/bin"
_arj_bin=$(find . -name arj -type f -executable 2>/dev/null | head -1)
if [ -n "$_arj_bin" ]; then
    install -m755 "$_arj_bin" "$OUT/usr/bin/arj"
else
    echo "ERROR: arj binary not found after build"
    find . -type f -executable 2>/dev/null | head -20
    exit 1
fi
""",
    host_deps = [
        "//packages/linux/dev-tools/build-systems/autoconf:autoconf",
    ],
)
