load("//defs:package.bzl", "package")

# HAProxy - The Reliable, High Performance TCP/HTTP Load Balancer

package(
    name = "haproxy",
    build_rule = "binary",
    version = "2.9.6",
    url = "https://www.haproxy.org/download/2.9/src/haproxy-2.9.6.tar.gz",
    sha256 = "208adf47c8fa83c54978034ba5c0110b7463c47078f119bd052342171a3b9a0b",
    description = "The Reliable, High Performance TCP/HTTP Load Balancer",
    homepage = "https://www.haproxy.org/",
    license = "GPL-2.0",
    deps = [
        "//packages/linux/system/libs/crypto/openssl:openssl",
        "//packages/linux/system/libs/utility/pcre2:pcre2",
        "//packages/linux/core/zlib:zlib",
        "//packages/linux/system/libs/crypto/libxcrypt:libxcrypt",
    ],
    install_script = """
mkdir -p "$OUT"
BUILD=$(mktemp -d)
cp -a "$SRCS"/. "$BUILD/"
cd "$BUILD"

# Build include and lib paths from all dependencies
INCLUDE_OPTS=""
LIB_OPTS=""
IFS=':' read -ra _DEP_ARRAY <<< "${DEP_BASE_DIRS:-}"
for _dep in "${_DEP_ARRAY[@]}"; do
    for _incdir in "$_dep/usr/include" "$_dep/include"; do
        if [ -d "$_incdir" ]; then
            INCLUDE_OPTS="$INCLUDE_OPTS -I$_incdir"
        fi
    done
    for _libdir in "$_dep/usr/lib64" "$_dep/usr/lib" "$_dep/lib64" "$_dep/lib"; do
        if [ -d "$_libdir" ]; then
            LIB_OPTS="$LIB_OPTS -L$_libdir -Wl,-rpath-link,$_libdir"
        fi
    done
done

make -j${MAKEOPTS:-$(nproc)} \
    TARGET=linux-glibc \
    USE_OPENSSL=1 \
    USE_ZLIB=1 \
    USE_PCRE2=1 \
    ADDINC="$INCLUDE_OPTS" \
    ADDLIB="$LIB_OPTS" \
    PREFIX=/usr

make install \
    DESTDIR="$OUT" \
    PREFIX=/usr

mkdir -p "$OUT/etc/haproxy"
mkdir -p "$OUT/var/lib/haproxy"
""",
)
