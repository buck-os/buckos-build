load("//defs:package_defs.bzl", "ebuild_package")

ebuild_package(
    name = "tahu",
    version = "0.5.15",
    src_uri = "https://github.com/eclipse/tahu/archive/refs/tags/v0.5.15.tar.gz",
    sha256 = "TODO",
    description = "Eclipse Tahu - Sparkplug B MQTT client libraries",
    homepage = "https://github.com/eclipse/tahu",
    license = "EPL-2.0",

    src_compile = """
        cd c/core
        make all
    """,

    src_install = """
        cd c/core

        # Install libraries
        mkdir -p "$DESTDIR/usr/lib64"
        cp lib/libtahu.a "$DESTDIR/usr/lib64/"
        cp lib/libtahu.so "$DESTDIR/usr/lib64/"

        # Install headers
        mkdir -p "$DESTDIR/usr/include/tahu"
        cp include/*.h "$DESTDIR/usr/include/tahu/"

        # Create pkg-config file
        mkdir -p "$DESTDIR/usr/lib64/pkgconfig"
        cat > "$DESTDIR/usr/lib64/pkgconfig/tahu.pc" << 'EOF'
prefix=/usr
exec_prefix=${prefix}
libdir=${exec_prefix}/lib64
includedir=${prefix}/include/tahu

Name: tahu
Description: Eclipse Tahu - Sparkplug B MQTT client libraries
Version: 0.5.15
Cflags: -I${includedir}
Libs: -L${libdir} -ltahu
EOF
    """,

    visibility = ["PUBLIC"],
)
