load("//defs:package_defs.bzl", "cmake_package")

# googleurl - Google URL parsing library from Chromium
# A C++ library for parsing and canonicalizing URLs based on Chromium's URL implementation
# This is Chrome's URL parsing library, adapted to work with standard build systems.
# Requires C++20 or later and -fno-strict-aliasing compile flag.

cmake_package(
    name = "googleurl",
    version = "0.0.1",
    source = "~/fbsource/third-party/googleurl",
    description = "Google URL parsing library (Chromium URL implementation)",
    homepage = "https://quiche.googlesource.com/googleurl",
    license = "BSD-3-Clause",
    deps = [
        "//packages/linux/dev-libs/text/icu:icu",
    ],
    patches = [
        "patches/add-cmake.patch",
    ],
    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DBUILD_SHARED_LIBS=ON",
        "-DCMAKE_CXX_STANDARD=20",
        "-DCMAKE_CXX_FLAGS=-fno-strict-aliasing",
    ],
    visibility = ["PUBLIC"],
)
