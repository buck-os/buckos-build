load("//defs/rules:ostree.bzl", "ostree_commit", "ostree_rootfs", "ostree_sysroot", "ostree_verify")

# Self-test for the ostree_commit rule (SPEC-006 P2): commit a tiny, fully
# deterministic tree so the resulting commit checksum is byte-stable and can
# be diffed across builds to prove reproducibility.
genrule(
    name = "demo-tree",
    out = "tree",
    cmd = "mkdir -p $OUT/usr/bin $OUT/usr/share && " +
          "printf '#!/bin/sh\\necho hello-buckos-ostree\\n' > $OUT/usr/bin/hello && " +
          "chmod 0755 $OUT/usr/bin/hello && " +
          "printf 'buckos ostree_commit demo\\n' > $OUT/usr/share/readme",
)

ostree_commit(
    name = "demo-commit",
    tree = ":demo-tree",
    branch = "buckos/demo",
    subject = "ostree_commit self-test",
    visibility = ["PUBLIC"],
)

# Signed variant (SPEC-007): sign the demo commit with the committed TEST
# ed25519 key. Building this runs `ostree sign --sign-type=ed25519`, so a bad
# key format fails the build; the resulting commit carries a `.commitmeta`
# with an `ostree.sign.ed25519` signature.
ostree_commit(
    name = "demo-commit-signed",
    tree = ":demo-tree",
    branch = "buckos/demo-signed",
    subject = "ostree_commit signing self-test",
    signing_key = "//defs/keys:ostree-test-key",
    visibility = ["PUBLIC"],
)

# Cryptographic verification self-test (SPEC-007 S3): the signer's key MUST
# verify the signed commit and a different key MUST be rejected.
ostree_verify(
    name = "demo-commit-verify",
    commit = ":demo-commit-signed",
    good_key = "//defs/keys:ostree-test-pub",
    bad_key = "//defs/keys:ostree-test-wrong-pub",
    visibility = ["PUBLIC"],
)

# Self-test for the ostree_rootfs transform (SPEC-006 P2): a mini rootfs with
# /etc, /home, /var content + mutable dirs, reshaped into ostree's layout,
# then committed.  Exercises the full composable pipeline:
#   rootfs tree -> ostree_rootfs -> ostree_commit
genrule(
    name = "mini-rootfs",
    out = "tree",
    cmd = " && ".join([
        "mkdir -p $OUT/usr/bin $OUT/etc $OUT/home/user $OUT/var/lib/foo $OUT/opt $OUT/root",
        "mkdir -p $OUT/usr/lib/modules/6.0.0-buckos",
        "printf '#!/bin/sh\\necho hi\\n' > $OUT/usr/bin/hi && chmod 0755 $OUT/usr/bin/hi",
        "printf 'BUCKOS=1\\n' > $OUT/etc/os-config",
        "printf 'ID=buckos\\nNAME=BuckOS\\nPRETTY_NAME=\"BuckOS mini\"\\nVERSION_ID=0\\n' > $OUT/etc/os-release",
        "printf 'profile\\n' > $OUT/home/user/.profile",
        "printf 'state\\n' > $OUT/var/lib/foo/state",
        # Dummy kernel so `ostree admin deploy` can populate /boot (it copies +
        # hashes vmlinuz; it does not validate that it is a real kernel).
        "printf 'DUMMYKERNEL\\n' > $OUT/usr/lib/modules/6.0.0-buckos/vmlinuz",
    ]),
)

ostree_rootfs(
    name = "mini-ostree-rootfs",
    tree = ":mini-rootfs",
    # Bake in the trusted key so test-ostree-rootfs can assert it lands.
    trusted_key = "//defs/keys:ostree-test-pub",
    visibility = ["PUBLIC"],
)

ostree_commit(
    name = "mini-ostree-commit",
    tree = ":mini-ostree-rootfs",
    branch = "buckos/mini",
    subject = "ostree_rootfs reshape self-test",
    visibility = ["PUBLIC"],
)

# Self-test for the ostree_sysroot deploy rule (SPEC-006 P3): deploy the
# committed image into a bootable sysroot (in a user namespace).  The mini
# rootfs carries a dummy kernel so `ostree admin deploy` can populate /boot.
ostree_sysroot(
    name = "mini-sysroot",
    commit = ":mini-ostree-commit",
    os = "buckos",
    visibility = ["PUBLIC"],
)

# ── Update-cycle fixtures (SPEC-006 P6) ──────────────────────────────
# Two tiny bootable commits, "A" and "B", that differ only by the marker
# their init echoes on the serial console. They feed three deploy states:
#   - base:        deploy A                 -> boots A
#   - updated:     deploy A, then B         -> boots B  (atomic update)
#   - rolledback:  deploy A, B, redeploy A  -> boots A  (rollback)
# The boot harness boots all three and asserts A / B / A.

_CYCLE_TREE_CMD = " && ".join([
    "mkdir -p $OUT/usr/bin $OUT/usr/sbin $OUT/usr/lib/modules/6.0.0-buckos $OUT/etc",
    "ln -s usr/bin $OUT/bin",
    "ln -s usr/sbin $OUT/sbin",
    "ln -s usr/lib $OUT/lib",
    'cp "$(location //packages/linux/core/busybox:busybox-static)/bin/busybox" $OUT/usr/bin/busybox && chmod 0755 $OUT/usr/bin/busybox',
    # Dummy kernel so `ostree admin deploy` can populate /boot (QEMU boots the
    # real bzImage via -kernel; the in-commit vmlinuz is never executed).
    "printf 'DUMMYKERNEL\\n' > $OUT/usr/lib/modules/6.0.0-buckos/vmlinuz",
])

genrule(
    name = "cycle-tree-a",
    out = "tree",
    cmd = _CYCLE_TREE_CMD + " && " + " && ".join([
        "printf 'ID=buckos\\nNAME=BuckOS\\nPRETTY_NAME=\"BuckOS cycle A\"\\nVERSION_ID=a\\n' > $OUT/etc/os-release",
        "printf '#!/usr/bin/busybox sh\\n/usr/bin/busybox mount -t proc proc /proc 2>/dev/null || true\\n/usr/bin/busybox echo CYCLE_BOOT_A\\n/usr/bin/busybox sync\\n/usr/bin/busybox poweroff -f\\n' > $OUT/usr/sbin/init",
        "chmod 0755 $OUT/usr/sbin/init",
    ]),
)

genrule(
    name = "cycle-tree-b",
    out = "tree",
    cmd = _CYCLE_TREE_CMD + " && " + " && ".join([
        "printf 'ID=buckos\\nNAME=BuckOS\\nPRETTY_NAME=\"BuckOS cycle B\"\\nVERSION_ID=b\\n' > $OUT/etc/os-release",
        "printf '#!/usr/bin/busybox sh\\n/usr/bin/busybox mount -t proc proc /proc 2>/dev/null || true\\n/usr/bin/busybox echo CYCLE_BOOT_B\\n/usr/bin/busybox sync\\n/usr/bin/busybox poweroff -f\\n' > $OUT/usr/sbin/init",
        "chmod 0755 $OUT/usr/sbin/init",
    ]),
)

ostree_rootfs(name = "cycle-rootfs-a", tree = ":cycle-tree-a", visibility = ["PUBLIC"])
ostree_rootfs(name = "cycle-rootfs-b", tree = ":cycle-tree-b", visibility = ["PUBLIC"])

ostree_commit(
    name = "cycle-commit-a",
    tree = ":cycle-rootfs-a",
    branch = "buckos/cycle-a",
    subject = "update-cycle A",
    visibility = ["PUBLIC"],
)

ostree_commit(
    name = "cycle-commit-b",
    tree = ":cycle-rootfs-b",
    branch = "buckos/cycle-b",
    subject = "update-cycle B",
    visibility = ["PUBLIC"],
)

ostree_sysroot(
    name = "cycle-sysroot-base",
    commit = ":cycle-commit-a",
    visibility = ["PUBLIC"],
)

ostree_sysroot(
    name = "cycle-sysroot-updated",
    commit = ":cycle-commit-a",
    update_commit = ":cycle-commit-b",
    visibility = ["PUBLIC"],
)

ostree_sysroot(
    name = "cycle-sysroot-rolledback",
    commit = ":cycle-commit-a",
    update_commit = ":cycle-commit-b",
    rollback = True,
    visibility = ["PUBLIC"],
)
