load("//defs/rules:ostree.bzl", "ostree_commit", "ostree_rootfs", "ostree_sysroot")

# Self-test for the ostree_commit rule (SPEC-006 P2): commit a tiny, fully
# deterministic tree so the resulting commit checksum is byte-stable and can
# be diffed across builds to prove reproducibility.
genrule(
    name = "demo-tree",
    out = "tree",
    cmd = "mkdir -p $OUT/usr/bin $OUT/usr/share && " +
          "printf '#!/bin/sh\\necho hello-buckos-ostree\\n' > $OUT/usr/bin/hello && " +
          "chmod 0755 $OUT/usr/bin/hello && " +
          "printf 'buckos ostree_commit demo\\n' > $OUT/usr/share/readme",
)

ostree_commit(
    name = "demo-commit",
    tree = ":demo-tree",
    branch = "buckos/demo",
    subject = "ostree_commit self-test",
    visibility = ["PUBLIC"],
)

# Self-test for the ostree_rootfs transform (SPEC-006 P2): a mini rootfs with
# /etc, /home, /var content + mutable dirs, reshaped into ostree's layout,
# then committed.  Exercises the full composable pipeline:
#   rootfs tree -> ostree_rootfs -> ostree_commit
genrule(
    name = "mini-rootfs",
    out = "tree",
    cmd = " && ".join([
        "mkdir -p $OUT/usr/bin $OUT/etc $OUT/home/user $OUT/var/lib/foo $OUT/opt $OUT/root",
        "mkdir -p $OUT/usr/lib/modules/6.0.0-buckos",
        "printf '#!/bin/sh\\necho hi\\n' > $OUT/usr/bin/hi && chmod 0755 $OUT/usr/bin/hi",
        "printf 'BUCKOS=1\\n' > $OUT/etc/os-config",
        "printf 'ID=buckos\\nNAME=BuckOS\\nPRETTY_NAME=\"BuckOS mini\"\\nVERSION_ID=0\\n' > $OUT/etc/os-release",
        "printf 'profile\\n' > $OUT/home/user/.profile",
        "printf 'state\\n' > $OUT/var/lib/foo/state",
        # Dummy kernel so `ostree admin deploy` can populate /boot (it copies +
        # hashes vmlinuz; it does not validate that it is a real kernel).
        "printf 'DUMMYKERNEL\\n' > $OUT/usr/lib/modules/6.0.0-buckos/vmlinuz",
    ]),
)

ostree_rootfs(
    name = "mini-ostree-rootfs",
    tree = ":mini-rootfs",
    visibility = ["PUBLIC"],
)

ostree_commit(
    name = "mini-ostree-commit",
    tree = ":mini-ostree-rootfs",
    branch = "buckos/mini",
    subject = "ostree_rootfs reshape self-test",
    visibility = ["PUBLIC"],
)

# Self-test for the ostree_sysroot deploy rule (SPEC-006 P3): deploy the
# committed image into a bootable sysroot (in a user namespace).  The mini
# rootfs carries a dummy kernel so `ostree admin deploy` can populate /boot.
ostree_sysroot(
    name = "mini-sysroot",
    commit = ":mini-ostree-commit",
    os = "buckos",
    visibility = ["PUBLIC"],
)
