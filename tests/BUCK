# Test targets — run with: buck2 test //tests:

# Expose seed host-tools (make, file, cc, etc.) to tests via PATH wrapper.
# With seed: wrapper sets PATH + LD_LIBRARY_PATH from host-tools.
# Without seed: wrapper is a passthrough.
test_host_env(
    name = "host-tools-env",
)

