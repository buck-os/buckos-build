        "DISK": "$(location //tests/fixtures/ima-test:ima-disk-signed)",
        "CMDLINE_EXTRA": "ima_appraise=enforce ima_test_mode=file_signed",
        "EXPECT_MARKER": "IMA-RESULT:PASS",
        "EXPECT_TEST_OUTPUT": "IMA-FILE-CONTENT",
